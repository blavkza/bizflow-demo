generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FinancialSettings {
  id               String   @id @default(cuid())
  currentPrimeRate Float    @default(11.75)
  updatedAt        DateTime @updatedAt
  updatedBy        String?

  @@map("financial_settings")
}

model User {
  id                   String             @id @default(cuid())
  userId               String             @unique
  email                String             @unique
  name                 String
  userName             String             @unique
  phone                String?
  avatar               String?
  role                 UserRole           @default(VIEWER)
  status               UserStatus         @default(ACTIVE)
  lastLogin            DateTime?
  timezone             String             @default("Africa/Johannesburg")
  language             String             @default("en")
  preferences          Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  permissions          UserPermission[]
  employeeId           String?            @unique
  userType             UserType           @default(ADMIN)
  GeneralSetting       GeneralSetting[]
  activityLogs         ActivityLog[]
  apiKeys              ApiKey[]
  ChatSession          ChatSession[]
  dashboardSettings    DashboardSettings?
  managedDepartments   Department[]       @relation("DepartmentManager")
  emergencyCallOuts    EmergencyCallOut[]
  Expense              Expense[]
  invoiceDocuments     InvoiceDocument[]
  createdInvoices      Invoice[]
  createdLenders       Lender[]
  createdLoanPayments  LoanPayment[]
  createdLoans         Loan[]
  notifications        Notification[]
  Order                Order[]
  passwordResets       PasswordReset[]
  projectTeams         ProjectTeam[]
  Project              Project[]
  createdQuotations    Quotation[]
  recurringInvoices    RecurringInvoice[]
  createdReports       Report[]
  sessions             Session[]
  timeEntries          TimeEntry[]
  managedTasks         Task[]             @relation("TaskLeader")
  resolvedToolRequests ToolRequest[]      @relation("ResolvedRequests")
  processedReturns     ToolReturn[]       @relation("ProcessedReturns")
  createdTransactions  Transaction[]
  employee             Employee?          @relation(fields: [employeeId], references: [id])
  freeLancerId         String?            @unique
  freeLancer           FreeLancer?        @relation(fields: [freeLancerId], references: [id])
  traineeId            String?            @unique
  trainee              Trainee?           @relation(fields: [traineeId], references: [id])
  Vendor               Vendor[]
  workLogs             WorkLog[]
  CallOutAssistant     CallOutAssistant[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GeneralSetting {
  id                 String       @id @default(cuid())
  userId             String
  companyName        String
  taxId              String
  phone              String
  phone2             String?
  phone3             String?
  website            String?
  paymentTerms       String?
  note               String?
  bankAccount        String?
  bankAccount2       String?
  bankName           String?
  bankName2          String?
  logo               String?
  email              String
  Address            String
  city               String
  province           String
  postCode           String
  createdAt          DateTime     @default(now())
  creditNoteNote     String?
  creditNoteTerms    String?
  deliveryNoteNote   String?
  deliveryNoteTerms  String?
  proFormaNote       String?
  proFormaTerms      String?
  purchaseOrderNote  String?
  purchaseOrderTerms String?
  supplierListNote   String?
  supplierListTerms  String?
  depositPaymentEnabled Boolean @default(false)
  depositPercentage     Float   @default(60)
  interest30Days        Float   @default(18)
  interest1To3Months    Float   @default(40)
  interest3To6Months    Float   @default(45)
  interest6To9Months    Float   @default(60)
  interest9To12Months   Float   @default(70)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  Employee           Employee[]
  FreeLancer         FreeLancer[]
  Trainee            Trainee[]
  Trainer            Trainer[]

  @@map("GeneralSettings")
}

model HRSettings {
  id                         String   @id @unique @default(cuid())
  paymentDay                 Int      @default(25)
  paymentMonth               String   @default("CURRENT")
  autoProcessPayroll         Boolean  @default(false)
  lateThreshold              Int      @default(15)
  halfDayThreshold           Float    @default(4.0)
  overtimeThreshold          Float    @default(8.0)
  workingDaysPerMonth        Int      @default(22)
  annualLeaveDays            Int      @default(21)
  sickLeaveDays              Int      @default(30)
  studyLeaveDays             Int      @default(5)
  maternityLeaveDays         Int      @default(120)
  paternityLeaveDays         Int      @default(10)
  carryOverEnabled           Boolean  @default(true)
  maxCarryOverDays           Int      @default(5)
  workingHoursPerDay         Int      @default(8)
  overtimeHourRate           Float    @default(50.00)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  updatedBy                  String?
  annualBonusEnabled         Boolean  @default(true)
  annualBonusPercentage      Float    @default(100)
  annualBonusType            String   @default("DECEMBER")
  appreciationBonusEnabled   Boolean  @default(true)
  courtOrderEnabled          Boolean  @default(true)
  damageLossEnabled          Boolean  @default(true)
  damageLossMaxPercentage    Float    @default(20)
  disciplinaryEnabled        Boolean  @default(true)
  disciplinaryMaxPercentage  Float    @default(50)
  funeralBenefitAmount       Float    @default(100)
  funeralBenefitEnabled      Boolean  @default(true)
  guaranteeFundEnabled       Boolean  @default(false)
  incentivePaymentEnabled    Boolean  @default(true)
  insuranceEnabled           Boolean  @default(true)
  loanRepaymentEnabled       Boolean  @default(true)
  medicalAidEnabled          Boolean  @default(true)
  medicalAidMaxDeduction     Float    @default(2000)
  meritBonusEnabled          Boolean  @default(true)
  overpaymentEnabled         Boolean  @default(true)
  overpaymentMaxPercentage   Float    @default(25)
  pensionEnabled             Boolean  @default(true)
  pensionPercentage          Float    @default(7.5)
  performanceBonusEnabled    Boolean  @default(true)
  performanceBonusType       String   @default("INDIVIDUAL")
  profitSharingEnabled       Boolean  @default(false)
  profitSharingPercentage    Float    @default(10)
  recognitionAwardEnabled    Boolean  @default(true)
  savingsEnabled             Boolean  @default(true)
  savingsMaxPercentage       Float    @default(15)
  spotBonusEnabled           Boolean  @default(true)
  thirteenthChequeEnabled    Boolean  @default(false)
  tradeUnionEnabled          Boolean  @default(false)
  uifEnabled                 Boolean  @default(true)
  uifPercentage              Float    @default(1)
  uniformPPEEnabled          Boolean  @default(true)
  uniformPPEMaxDeduction     Float    @default(500)
  appreciationBonusAmount    Float    @default(250)
  attendanceBonusEnabled     Boolean  @default(true)
  attendanceBonusPercentage  Float    @default(2)
  guaranteeFundAmount        Float    @default(20)
  incentivePaymentPercentage Float    @default(4)
  insurancePercentage        Float    @default(0.5)
  meritBonusPercentage       Float    @default(3)
  overtimeBonusEnabled       Boolean  @default(true)
  overtimeBonusPercentage    Float    @default(10)
  performanceBonusPercentage Float    @default(5)
  recognitionAwardAmount     Float    @default(300)
  spotBonusAmount            Float    @default(500)
  taxEnabled                 Boolean  @default(true)
  taxTableYear               String   @default("2025")
  tradeUnionAmount           Float    @default(50)
  workingHoursWeekend        Int      @default(4)
  WeekendovertimeThreshold   Float    @default(4.0)
  breakReminderMinutes       Int      @default(5)
  maxBreaksPerDay            Int      @default(2)
  totalBreakDurationMinutes  Int      @default(60)
  lunchTimeWindowEnd         String?  @default("14:00")
  lunchTimeWindowStart       String?  @default("13:00")
  teaTimeWindowEnd           String?  @default("11:00")
  teaTimeWindowStart         String?  @default("10:00")

  @@map("hr_settings")
}

model DashboardSettings {
  id                   String    @id @default(cuid())
  userId               String    @unique
  showFinancialAlerts  Boolean   @default(true)
  showProjectAlerts    Boolean   @default(true)
  showTaskAlerts       Boolean   @default(true)
  showEmployeeAlerts   Boolean   @default(true)
  showFreelancerAlerts Boolean   @default(true)
  defaultChartType     ChartType @default(BAR)
  showInvoiceChart     Boolean   @default(true)
  showQuotationChart   Boolean   @default(true)
  showExpenseChart     Boolean   @default(true)
  showRevenueChart     Boolean   @default(true)
  payrollAlertDays     Int       @default(5)
  dueDateAlertDays     Int       @default(3)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])

  @@map("dashboard_settings")
}

model POSSetting {
  id                 String   @id @default(cuid())
  vatEnabled         Boolean  @default(true)
  vatRate            Float    @default(0.15)
  deliveryEnabled    Boolean  @default(true)
  deliveryFee        Float    @default(50.00)
  freeDeliveryAbove  Float    @default(500.00)
  discountEnabled    Boolean  @default(true)
  maxDiscountRate    Float    @default(20.00)
  receiptHeader      String?
  receiptFooter      String?
  printAutomatically Boolean  @default(false)
  emailReceipt       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Coupon {
  id                String        @id @default(cuid())
  code              String        @unique
  type              DiscountType
  value             Decimal       @db.Decimal(10, 2)
  minOrderAmount    Decimal?      @db.Decimal(10, 2)
  maxDiscountAmount Decimal?      @db.Decimal(10, 2)
  startDate         DateTime
  endDate           DateTime?
  usageLimit        Int?
  usedCount         Int           @default(0)
  isActive          Boolean       @default(true)
  description       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  sales             Sale[]
  products          ShopProduct[] @relation("CouponToShopProduct")

  @@map("coupons")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Department {
  id               String            @id @default(cuid())
  name             String
  description      String?
  code             String            @unique
  managerId        String?
  parentId         String?
  status           DepartmentStatus  @default(ACTIVE)
  currency         String            @default("ZAR")
  location         String?
  floor            String?
  building         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  updater          String?
  budgets          Budget[]
  manager          User?             @relation("DepartmentManager", fields: [managerId], references: [id])
  parent           Department?       @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children         Department[]      @relation("DepartmentHierarchy")
  employees        Employee[]        @relation("DepartmentEmployees")
  freelancers      FreeLancer[]      @relation("DepartmentFreelancers")
  trainees         Trainee[]         @relation("DepartmentTrainees")
  trainers         Trainer[]         @relation("DepartmentTrainers")
  invoiceDocuments InvoiceDocument[]
  invoices         Invoice[]
  quotations       Quotation[]
  targets          Target[]
  expenses         Transaction[]

  @@map("departments")
}

model Employee {
  id                       String                 @id @default(cuid())
  employeeNumber           String                 @unique
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  avatar                   String?
  position                 String
  departmentId             String?
  generalSettingId         String?
  currency                 String                 @default("ZAR")
  hireDate                 DateTime
  terminationDate          DateTime?
  status                   EmployeeStatus         @default(ACTIVE)
  idNumber                 String?
  taxNumber                String?
  nationality              String?
  maritalStatus            MaritalStatus?
  address                  String?
  city                     String?
  province                 String?
  postalCode               String?
  country                  String                 @default("South Africa")
  emergencyName            String?
  emergencyPhone           String?
  emergencyRelation        String?
  emergencyAddress         String?
  bankName                 String?
  accountNumber            String?
  branchCode               String?
  accountType              String?
  contractType             ContractType?
  workSchedule             String?
  probationEnd             DateTime?
  scheduledKnockIn         String?
  scheduledKnockOut        String?
  workingDays              String[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  createdBy                String?
  annualLeaveDays          Int                    @default(21)
  sickLeaveDays            Int                    @default(30)
  studyLeaveDays           Int                    @default(5)
  maternityLeaveDays       Int                    @default(120)
  paternityLeaveDays       Int                    @default(10)
  unpaidLeaveDays          Int                    @default(0)
  dailySalary              Decimal                @db.Decimal(15, 2)
  monthlySalary            Decimal                @db.Decimal(15, 2)
  salaryType               SalaryType?            @default(MONTHLY)
  additionalInfo           String?
  allergies                String?
  emergencyContacts        Json?
  firstAidNeeds            String?
  medicalCondition         String?
  restrictions             String?
  riskLevel                String?
  overtimeHourRate         Float                  @default(50.00)
  emergencyCallOutRate     Float                  @default(0.00)
  canCheckByGPS            Boolean                @default(false)
  expoPushToken            String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  dayOff                   Int                    @default(0)
  leaveRequests            LeaveRequest[]
  Note                     Note[]
  AttendanceRecord         AttendanceRecord[]
  documents                Document[]
  emergencyCallOuts        EmergencyCallOut[]
  employeeNotification     EmployeeNotification[]
  department               Department?            @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  generalSetting           GeneralSetting?        @relation(fields: [generalSettingId], references: [id])
  kpiResults               KpiResult[]
  overtimeRequests         OvertimeRequest[]
  payments                 Payment[]
  targets                  Target[]
  toolRequests             ToolRequest[]
  toolReturns              ToolReturn[]
  user                     User?
  Warning                  Warning[]
  tools                    Tool[]                 @relation("EmployeeTools")
  bypassRules              AttendanceBypassRule[] @relation("BypassRuleEmployees")
  assignedTasks            Task[]                 @relation("TaskAssignments")
  CallOutAssistant         CallOutAssistant[]
  assistantInProjects      Project[]              @relation("ProjectAssistantEmployees")

  toolMovements ToolMovement[]
  toolChecks    ToolCheck[]

  @@index([departmentId])
  @@index([status])
  @@map("employees")
}

model FreeLancer {
  id                       String                 @id @default(cuid())
  freeLancerNumber         String                 @unique
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  avatar                   String?
  position                 String
  departmentId             String?
  generalSettingId         String?
  salary                   Decimal                @db.Decimal(15, 2)
  currency                 String                 @default("ZAR")
  hireDate                 DateTime
  terminationDate          DateTime?
  status                   FreeLancerStatus       @default(ACTIVE)
  reliable                 Boolean?
  idNumber                 String?
  taxNumber                String?
  nationality              String?
  maritalStatus            MaritalStatus?
  address                  String?
  city                     String?
  province                 String?
  postalCode               String?
  country                  String                 @default("South Africa")
  emergencyName            String?
  emergencyPhone           String?
  emergencyRelation        String?
  emergencyAddress         String?
  bankName                 String?
  accountNumber            String?
  branchCode               String?
  accountType              String?
  contractType             ContractType?
  workSchedule             String?
  probationEnd             DateTime?
  scheduledKnockIn         String?
  scheduledKnockOut        String?
  workingDays              String[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  createdBy                String?
  annualLeaveDays          Int                    @default(21)
  sickLeaveDays            Int                    @default(30)
  studyLeaveDays           Int                    @default(5)
  maternityLeaveDays       Int                    @default(120)
  paternityLeaveDays       Int                    @default(10)
  unpaidLeaveDays          Int                    @default(0)
  additionalInfo           String?
  allergies                String?
  emergencyContacts        Json?
  firstAidNeeds            String?
  medicalCondition         String?
  restrictions             String?
  riskLevel                String?
  overtimeHourRate         Float                  @default(50.00)
  emergencyCallOutRate     Float                  @default(0.00)
  expoPushToken            String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  leaveRequests            LeaveRequest[]
  notes                    Note[]
  attendanceRecords        AttendanceRecord[]
  documents                Document[]
  emergencyCallOuts        EmergencyCallOut[]
  employeeNotification     EmployeeNotification[]
  department               Department?            @relation("DepartmentFreelancers", fields: [departmentId], references: [id])
  generalSetting           GeneralSetting?        @relation(fields: [generalSettingId], references: [id])
  kpiResults               KpiResult[]
  overtimeRequests         OvertimeRequest[]
  payments                 Payment[]
  targets                  Target[]
  toolRequests             ToolRequest[]
  toolReturns              ToolReturn[]
  warnings                 Warning[]
  tools                    Tool[]                 @relation("FreelancerTools")
  bypassRules              AttendanceBypassRule[] @relation("BypassRuleFreelancers")
  assignedTasks            Task[]                 @relation("FreeLancerTaskAssignments")
  assistantInProjects      Project[]              @relation("ProjectAssistantFreelancers")
  user                     User?
  CallOutAssistant         CallOutAssistant[]

  toolMovements ToolMovement[]
  toolChecks    ToolCheck[]

  @@index([departmentId])
  @@index([status])
  @@map("freelancers")
}

model Trainee {
  id                       String                 @id @default(cuid())
  traineeNumber            String                 @unique
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  avatar                   String?
  position                 String
  departmentId             String?
  generalSettingId         String?
  salary                   Decimal                @db.Decimal(15, 2)
  currency                 String                 @default("ZAR")
  hireDate                 DateTime
  terminationDate          DateTime?
  status                   TraineeStatus          @default(ACTIVE)
  reliable                 Boolean?
  idNumber                 String?
  taxNumber                String?
  nationality              String?
  maritalStatus            MaritalStatus?
  address                  String?
  city                     String?
  province                 String?
  postalCode               String?
  country                  String                 @default("South Africa")
  emergencyName            String?
  emergencyPhone           String?
  emergencyRelation        String?
  emergencyAddress         String?
  bankName                 String?
  accountNumber            String?
  branchCode               String?
  accountType              String?
  contractType             ContractType?
  workSchedule             String?
  probationEnd             DateTime?
  scheduledKnockIn         String?
  scheduledKnockOut        String?
  workingDays              String[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  createdBy                String?
  annualLeaveDays          Int                    @default(21)
  sickLeaveDays            Int                    @default(30)
  studyLeaveDays           Int                    @default(5)
  maternityLeaveDays       Int                    @default(120)
  paternityLeaveDays       Int                    @default(10)
  unpaidLeaveDays          Int                    @default(0)
  additionalInfo           String?
  allergies                String?
  emergencyContacts        Json?
  firstAidNeeds            String?
  medicalCondition         String?
  restrictions             String?
  riskLevel                String?
  overtimeHourRate         Float                  @default(50.00)
  emergencyCallOutRate     Float                  @default(0.00)
  expoPushToken            String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  leaveRequests            LeaveRequest[]
  notes                    Note[]
  attendanceRecords        AttendanceRecord[]
  documents                Document[]
  emergencyCallOuts        EmergencyCallOut[]
  employeeNotification     EmployeeNotification[]
  department               Department?            @relation("DepartmentTrainees", fields: [departmentId], references: [id])
  generalSetting           GeneralSetting?        @relation(fields: [generalSettingId], references: [id])
  kpiResults               KpiResult[]
  overtimeRequests         OvertimeRequest[]
  payments                 Payment[]
  targets                  Target[]
  toolRequests             ToolRequest[]
  toolReturns              ToolReturn[]
  warnings                 Warning[]
  tools                    Tool[]                 @relation("TraineeTools")
  bypassRules              AttendanceBypassRule[] @relation("BypassRuleTrainees")
  assignedTasks            Task[]                 @relation("TraineeTaskAssignments")
  assistantInProjects      Project[]              @relation("ProjectAssistantTrainees")
  user                     User?
  CallOutAssistant         CallOutAssistant[]

  toolMovements ToolMovement[]
  toolChecks    ToolCheck[]

  @@index([departmentId])
  @@index([status])
  @@map("trainees")
}

enum TraineeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  SUSPENDED
  PROSPECT
  BLACKLISTED
}

model Trainer {
  id                       String        @id @default(cuid())
  trainerNumber            String        @unique
  firstName                String
  lastName                 String
  email                    String?
  phone                    String?
  avatar                   String?
  position                 String
  specialization           String?
  departmentId             String?
  generalSettingId         String?
  salary                   Decimal       @db.Decimal(15, 2)
  currency                 String        @default("ZAR")
  hireDate                 DateTime
  terminationDate          DateTime?
  status                   TrainerStatus @default(ACTIVE)
  idNumber                 String?
  taxNumber                String?
  nationality              String?
  maritalStatus            MaritalStatus?
  address                  String?
  city                     String?
  province                 String?
  postalCode               String?
  country                  String        @default("South Africa")
  emergencyName            String?
  emergencyPhone           String?
  emergencyRelation        String?
  emergencyAddress         String?
  bankName                 String?
  accountNumber            String?
  branchCode               String?
  accountType              String?
  contractType             ContractType?
  workSchedule             String?
  probationEnd             DateTime?
  scheduledKnockIn         String?
  scheduledKnockOut        String?
  workingDays              String[]
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  createdBy                String?
  additionalInfo           String?
  overtimeHourRate         Float         @default(50.00)
  emergencyCallOutRate     Float         @default(0.00)
  expoPushToken            String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  department               Department?   @relation("DepartmentTrainers", fields: [departmentId], references: [id])
  generalSetting           GeneralSetting? @relation(fields: [generalSettingId], references: [id])

  @@index([departmentId])
  @@index([status])
  @@map("trainers")
}

enum TrainerStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  SUSPENDED
  PROSPECT
}

model AttendanceBypassRule {
  id                 String       @id @default(cuid())
  startDate          DateTime
  endDate            DateTime
  bypassCheckIn      Boolean      @default(false)
  bypassCheckOut     Boolean      @default(false)
  customCheckInTime  String?
  customCheckOutTime String?
  reason             String?
  createdBy          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  employees          Employee[]   @relation("BypassRuleEmployees")
  freelancers        FreeLancer[] @relation("BypassRuleFreelancers")
  trainees           Trainee[]    @relation("BypassRuleTrainees")

  @@index([startDate])
  @@index([endDate])
  @@map("attendance_bypass_rules")
}

model AttendanceRecord {
  id                String           @id @default(cuid())
  employeeId        String?
  date              DateTime         @db.Date
  checkIn           DateTime?
  checkOut          DateTime?
  breakStart        DateTime?
  breakEnd          DateTime?
  checkInLat        Decimal?         @db.Decimal(10, 8)
  checkInLng        Decimal?         @db.Decimal(11, 8)
  checkOutLat       Decimal?         @db.Decimal(10, 8)
  checkOutLng       Decimal?         @db.Decimal(11, 8)
  checkInAddress    String?
  checkOutAddress   String?
  checkInMethod     CheckInMethod?   @default(MANUAL)
  scheduledKnockIn  String?
  scheduledKnockOut String?
  regularHours      Decimal?         @db.Decimal(5, 2)
  overtimeHours     Decimal?         @db.Decimal(5, 2)
  breakDuration     Int?
  status            AttendanceStatus @default(PRESENT)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  freeLancerId      String?
  isWeekend         Boolean          @default(true)
  bypassApplied     Boolean          @default(false)
  bypassRuleId      String?
  customCheckInTime DateTime?
  overtimeRequestId String?
  employee          Employee?        @relation(fields: [employeeId], references: [id])
  freeLancer        FreeLancer?      @relation(fields: [freeLancerId], references: [id])
  traineeId         String?
  trainee           Trainee?         @relation(fields: [traineeId], references: [id])
  overtimeRequest   OvertimeRequest? @relation(fields: [overtimeRequestId], references: [id])
  breaks            BreakRecord[]

  @@unique([employeeId, date])
