// ============================================================================
// PAYROLL MANAGEMENT
// ============================================================================

// =============================================================================
// Expanses
// =============================================================================

model Vendor {
  id                 String  @id @default(cuid())
  name               String
  fullName           String?
  email              String?
  phone              String
  phone2             String?
  website            String?
  address            String?
  taxNumber          String?
  registrationNumber String?
  type               String  @default("SUPPLIER")
  currency           String  @default("ZAR")
  paymentTerms       String?
  notes              String?

  status VendorStatus @default(ACTIVE)

  categories ProductCategory[] @relation("VendorCategories")

  // System
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Relations
  expenses          Expense[]
  Document          Document[]
  productCategories ProductCategory[]

  @@map("vendors")
}

model Expense {
  expenseNumber String  @unique
  id            String  @id @default(cuid())
  description   String
  categoryId    String
  vendorEmail   String?
  vendorPhone   String?

  // Amounts
  totalAmount     Decimal @db.Decimal(12, 2)
  paidAmount      Decimal @default(0) @db.Decimal(12, 2)
  remainingAmount Decimal @db.Decimal(12, 2)

  // Status & Priority
  status   ExpenseStatus   @default(PENDING)
  priority ExpensePriority @default(MEDIUM)

  // Dates
  dueDate     DateTime  @db.Date
  paidDate    DateTime? @db.Date
  createdDate DateTime  @default(now())

  // Payment Details
  paymentMethod String?
  accountCode   String?
  projectCode   String?

  // Approval
  approvedBy   String?
  approvedDate DateTime?

  // Additional Info
  notes       String?
  attachments Json?

  // System
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expenseDate DateTime @default(now())

  // Relations
  payments  ExpensePayment[]
  Project   Project?         @relation(fields: [projectId], references: [id])
  projectId String?
  Invoice   Invoice?         @relation(fields: [invoiceId], references: [id])
  invoiceId String?
  Vendor    Vendor?          @relation(fields: [vendorId], references: [id])
  vendorId  String?
  category  Category?        @relation(fields: [categoryId], references: [id])

  @@map("expenses")
}

model ExpensePayment {
  id        String  @id @default(cuid())
  expenseId String
  expense   Expense @relation(fields: [expenseId], references: [id])

  amount      Decimal       @db.Decimal(10, 2)
  paymentDate DateTime      @db.Date
  method      String
  reference   String?
  status      PaymentStatus @default(PENDING)

  paidBy String
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  transactionId String?

  @@map("expense_payments")
}

model Product {
  id        String   @id @default(uuid())
  category  String
  size      String
  price     Decimal
  panels    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  images      String?

  products ShopProduct[]
  vendors  Vendor[]      @relation("VendorCategories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  String?

  @@map("Productcategories")
}

model ShopProduct {
  id          String  @id @default(cuid())
  name        String
  description String?
  sku         String  @unique
  category    String

  // Pricing
  price              Decimal  @db.Decimal(10, 2)
  costPrice          Decimal? @db.Decimal(10, 2)
  priceBeforeTax     Decimal? @db.Decimal(10, 2)
  costPriceBeforeTax Decimal? @db.Decimal(10, 2)

  priceInputMode String @default("AFTER_TAX")

  // Inventory
  stock    Int  @default(0)
  minStock Int  @default(0)
  maxStock Int?

  // Product Details
  weight     Decimal? @db.Decimal(8, 3)
  dimensions String?
  color      String?
  size       String?
  brand      String?

  // Status
  status   ProductStatus @default(ACTIVE)
  featured Boolean       @default(false)

  // Images
  images Json? // Array of image URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creater String?

  // Relations
  subpackages       SubpackageProduct[]
  orderItems        OrderItem[]
  stockMovements    StockMovement[]
  saleItems         SaleItem[]
  productDocuments  ProductDocument[]
  ProductCategory   ProductCategory?    @relation(fields: [productCategoryId], references: [id])
  productCategoryId String?
  quotationItems    QuotationItem[]
  invoiceItems      InvoiceItem[]
  package           Package?            @relation(fields: [packageId], references: [id])
  packageId         String?
  saleQuoteItems    SaleQuoteItem[]
  stockAwaits       StockAwait[]

  @@map("shopProducts")
}

model ProductDocument {
  id            String       @id @default(cuid())
  name          String
  url           String
  type          DocumentType
  size          Int
  mimeType      String
  shopProductId String
  shopProduct   ShopProduct  @relation(fields: [shopProductId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@map("product_documents")
}

model StockMovement {
  id            String            @id @default(cuid())
  shopProductId String
  type          StockMovementType
  quantity      Int
  reason        String?
  reference     String?
  previousStock Int
  newStock      Int
  createdAt     DateTime          @default(now())

  creater String?

  shopProduct ShopProduct @relation(fields: [shopProductId], references: [id])

  @@map("stock_movements")
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  saleId      String @unique
  sale        Sale   @relation(fields: [saleId], references: [id])

  // Order Details
  status       OrderStatus @default(PENDING)
  deliveryDate DateTime?
  assignedTo   String? // Staff assigned for delivery

  // Tracking
  carrier        String?
  trackingNumber String?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  User       User?       @relation(fields: [userId], references: [id])
  userId     String?
  OrderItem  OrderItem[]
  Customer   Customer?   @relation(fields: [customerId], references: [id])
  customerId String?
  package    Package?    @relation(fields: [packageId], references: [id])
  packageId  String?

  @@map("orders")
}

model SaleQuote {
  id          String    @id @default(cuid())
  quoteNumber String    @unique
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  // Customer info
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Quote Details
  status     QuoteStatus @default(PENDING)
  expiryDate DateTime?
  notes      String?

  // Delivery
  isDelivery           Boolean @default(false)
  deliveryAddress      String?
  deliveryInstructions String?

  // Amounts
  subtotal        Float
  discount        Float @default(0)
  discountPercent Float @default(0)
  tax             Float @default(0)
  deliveryFee     Float @default(0)
  total           Float

  // Relations
  items       SaleQuoteItem[]
  convertedTo Sale?           @relation("QuoteToSale")

  // Dates
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String
  stockAwaits StockAwait[]

  @@map("sale_quotes")
}

model SaleQuoteItem {
  id            String      @id @default(cuid())
  quoteId       String
  quote         SaleQuote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity Int
  price    Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  // Track if product had negative stock when converted
  hadNegativeStock Boolean @default(false)
  awaitedQuantity  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sale_quote_items")
}

model StockAwait {
  id            String      @id @default(cuid())
  saleId        String?
  sale          Sale?       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  quoteId       String?
  quote         SaleQuote?  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  shopProductId String
  shopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity Int
  status   StockAwaitStatus @default(PENDING)
  notes    String?

  resolvedAt DateTime?
  resolvedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([saleId, shopProductId])
  @@unique([quoteId, shopProductId])
  @@map("stock_awaits")
}

model Sale {
  id         String     @id @default(cuid())
  saleNumber String     @unique
  quoteId    String?    @unique
  quote      SaleQuote? @relation("QuoteToSale", fields: [quoteId], references: [id])
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id])

  // Customer info for walk-in customers
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Sale Details
  status SaleStatus @default(COMPLETED)

  // Delivery Information
  isDelivery           Boolean @default(false)
  deliveryFee          Float   @default(0)
  deliveryAddress      String?
  deliveryInstructions String?

  // Amounts
  subtotal        Float
  tax             Float @default(0)
  discount        Float @default(0)
  discountPercent Float @default(0)
  deliveryAmount  Float @default(0)
  total           Float

  refundedAmount Decimal @default(0) @db.Decimal(10, 2)
  refundedTax    Decimal @default(0) @db.Decimal(10, 2)

  // Payment
  paymentStatus  ShopPaymentStatus @default(COMPLETED)
  paymentMethod  PaymentMethod
  amountReceived Float?
  change         Float?

  // Receipt
  receiptSent  Boolean @default(false)
  receiptEmail String?

  // Dates
  saleDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String

  // Relations
  items      SaleItem[]
  orderId    String?
  Order      Order?
  Refund     Refund[]
  StockAwait StockAwait[]

  @@map("sales")
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  shopProductId String
  ShopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity Int
  price    Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  // Track stock information
  hadNegativeStock Boolean @default(false)
  awaitedQuantity  Int     @default(0)

  RefundItem RefundItem[]

  @@map("sale_items")
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])
  shopProductId String
  ShopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity Int
  price    Float
  total    Float

  @@map("order_items")
}

model Refund {
  id           String @id @default(cuid())
  refundNumber String @unique
  saleId       String
  sale         Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  // Refund Details
  status    RefundStatus @default(PENDING)
  reason    String
  method    RefundMethod
  amount    Float
  taxAmount Float        @default(0)

  // Items being refunded
  items RefundItem[]

  // Approval workflow
  requestedBy     String
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  notes           String?

  // Completion
  processedBy String?
  processedAt DateTime?

  // Relations
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactionId String?

  @@map("refunds")
}

model RefundItem {
  id       String @id @default(cuid())
  refundId String
  refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  saleItemId String
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id])

  quantity  Int
  price     Float
  total     Float
  taxAmount Float @default(0)

  @@map("refund_items")
}

model Package {
  id               String      @id @default(cuid())
  name             String
  description      String?
  shortDescription String?
  categoryId       String
  classification   String?
  notes            String?
  packageType      PackageType @default(BUNDLE)

  status   PackageStatus @default(ACTIVE)
  featured Boolean       @default(false)
  isPublic Boolean       @default(true)

  images    Json?
  thumbnail String?

  salesCount   Int     @default(0)
  totalRevenue Decimal @default(0) @db.Decimal(12, 2)

  tags     String[]
  benefits String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subpackages  Subpackage[]
  invoices     Invoice[]
  quotations   Quotation[]
  shopProducts ShopProduct[]
  orders       Order[]
  services     Service[]
  category     Category      @relation(fields: [categoryId], references: [id])

  @@map("packages")
}

model Subpackage {
  id               String  @id @default(cuid())
  packageId        String
  name             String
  description      String?
  shortDescription String?

  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  discount      Int?
  discountType  String?

  duration String?

  status    PackageStatus @default(ACTIVE)
  isDefault Boolean       @default(false)

  sortOrder Int @default(0)

  features String[]

  salesCount Int     @default(0)
  revenue    Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  products   SubpackageProduct[]
  services   SubpackageService[]
  invoices   Invoice[]
  quotations Quotation[]

  @@map("subpackages")
}

model SubpackageProduct {
  id           String      @id @default(cuid())
  subpackage   Subpackage  @relation(fields: [subpackageId], references: [id], onDelete: Cascade)
  subpackageId String
  product      ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  quantity     Int         @default(1)
  unitPrice    Decimal?    @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subpackageId, productId])
  @@map("subpackage_products")
}

model SubpackageService {
  id           String     @id @default(cuid())
  subpackage   Subpackage @relation(fields: [subpackageId], references: [id], onDelete: Cascade)
  subpackageId String
  service      Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId    String
  quantity     Int        @default(1)
  unitPrice    Decimal?   @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subpackageId, serviceId])
  @@map("subpackage_services")
}

model Customer {
  id        String  @id @default(cuid())
  firstName String
  lastName  String?
  email     String? @unique
  phone     String?

  // Address
  address    String?
  city       String?
  province   Province?
  postalCode String?
  country    String    @default("South Africa")

  // Customer Details
  dateOfBirth DateTime? @db.Date
  gender      Gender?

  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders     Order[]
  sales      Sale[]
  saleQuotes SaleQuote[]

  @@map("customers")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model Tool {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String?
  canBeRented Boolean @default(true)

  // Pricing & Rental Rates
  purchasePrice     Decimal   @db.Decimal(12, 2)
  purchaseDate      DateTime? @db.Date
  rentalRateDaily   Decimal?  @db.Decimal(10, 2)
  rentalRateWeekly  Decimal?  @db.Decimal(10, 2)
  rentalRateMonthly Decimal?  @db.Decimal(10, 2)

  // Status & Condition
  status    ToolStatus    @default(AVAILABLE)
  condition ToolCondition @default(GOOD)

  // Images
  primaryImage String?

  // System
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  images Json?

  rentals         ToolRental[]
  InterUse        ToolInterUse[]
  maintenanceLogs ToolMaintenanceLog[]
  rentalRequests  RentalRequest[]

  @@map("tools")
}

model ToolRental {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Renter Information
  businessName  String
  renterContact String?
  renterEmail   String?
  renterPhone   String?

  // Rental Period
  rentalStartDate DateTime @db.Date
  rentalEndDate   DateTime @db.Date

  // Payment
  rentalRate Decimal  @db.Decimal(10, 2)
  rentalDays Int?
  totalCost  Decimal? @db.Decimal(10, 2)

  // Payment Status
  paymentStatus   PaymentStatus @default(PENDING)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal?      @db.Decimal(10, 2)
  paidDate        DateTime?     @db.Date
  returnDate      DateTime?

  // Status
  status RentalStatus @default(ACTIVE)

  // Additional Info
  notes             String?
  returnCondition   String?
  damageReported    Boolean @default(false)
  damageDescription String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  quotationId String?
  invoice     Invoice?   @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
  client      Client?    @relation(fields: [clientId], references: [id])
  clientId    String?

  @@map("tool_rentals")
}

model ToolInterUse {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Rental Period
  useStartDate DateTime @db.Date
  useEndDate   DateTime @db.Date

  // Status
  status ToolInterUseStatus @default(ACTIVE)

  // Additional Info
  notes             String?
  damageReported    Boolean @default(false)
  damageDescription String?
  relisedBy         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@map("tool_interUses")
}

model ToolMaintenanceLog {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  maintenanceType String
  cost            Decimal  @db.Decimal(10, 2)
  maintenanceDate DateTime @db.Date
  notes           String?
  assignedTo      String?
  processedBy     String?

  createdAt DateTime @default(now())

  @@map("tool_maintenance_logs")
}

model Service {
  id          String        @id @default(cuid())
  name        String
  description String
  category    String
  categoryId  String
  amount      Float
  currency    String?       @default("ZAR")
  duration    String?
  status      ServiceStatus @default(ACTIVE)
  features    String[]

  // Stats
  clients           Int   @default(0)
  revenue           Float @default(0)
  completedProjects Int   @default(0)
  activeProjects    Int   @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subpackages SubpackageService[]

  projects       Project[]
  quotationItems QuotationItem[]
  invoiceItems   InvoiceItem[]
  package        Package?        @relation(fields: [packageId], references: [id])
  packageId      String?

  @@map("services")
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

model RentalRequest {
  id     String  @id @default(cuid())
  toolId String?
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: SetNull)

  // Requester Information
  requesterName     String
  requesterEmail    String
  requesterPhone    String?
  requesterBusiness String

  // Rental Details
  requestedStartDate DateTime @db.Date
  requestedEndDate   DateTime @db.Date
  rentalDays         Int?
  estimatedCost      Decimal? @db.Decimal(10, 2)

  // Request Status
  status   RequestStatus @default(PENDING)
  priority Priority      @default(MEDIUM)

  // Approval
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  // Additional Info
  purpose             String?
  specialRequirements String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_requests")
}

// ============================================================================
// TARGETS & KPI MANAGEMENT
// ============================================================================

model Target {
  id           String     @id @default(cuid())
  name         String
  description  String?
  type         TargetType
  category     String?
  targetValue  Decimal    @db.Decimal(15, 2)
  currentValue Decimal    @default(0) @db.Decimal(15, 2)
  unit         String?
  currency     String?    @default("ZAR")

  // Timeline
  startDate DateTime
  endDate   DateTime

  // Assignment
  employeeId   String?
  departmentId String?

  // Status
  status   TargetStatus @default(ACTIVE)
  priority Priority     @default(MEDIUM)

  // Progress
  progress Decimal @default(0) @db.Decimal(5, 2) // Percentage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  employee     Employee?      @relation(fields: [employeeId], references: [id])
  department   Department?    @relation(fields: [departmentId], references: [id])
  updates      TargetUpdate[]
  kpis         Kpi[]
  freeLancer   FreeLancer?    @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@index([employeeId])
  @@index([departmentId])
  @@index([status])
  @@map("targets")
}

model TargetUpdate {
  id        String  @id @default(cuid())
  targetId  String
  value     Decimal @db.Decimal(15, 2)
  notes     String?
  updatedBy String?

  createdAt DateTime @default(now())

  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@map("target_updates")
}

model Kpi {
  id          String       @id @default(cuid())
  name        String
  description String?
  formula     String?
  unit        String?
  targetId    String?
  frequency   KpiFrequency @default(MONTHLY)
  isActive    Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  target  Target?     @relation(fields: [targetId], references: [id])
  results KpiResult[]

  @@map("kpis")
}

model KpiResult {
  id         String   @id @default(cuid())
  kpiId      String
  employeeId String?
  value      Decimal  @db.Decimal(15, 2)
  period     DateTime
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpi          Kpi         @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  employee     Employee?   @relation(fields: [employeeId], references: [id])
  freeLancer   FreeLancer? @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@unique([kpiId, employeeId, period])
  @@index([kpiId])
  @@index([period])
  @@map("kpi_results")
}

// ============================================================================
// REPORTING & ANALYTICS
// ============================================================================

model Report {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        ReportType
  config      Json
  schedule    Json?
  isScheduled Boolean    @default(false)
  isPublic    Boolean    @default(false)

  // Generation
  lastRunAt DateTime?
  nextRunAt DateTime?
  status    ReportStatus @default(DRAFT)

  // Relations
  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator    User              @relation(fields: [createdBy], references: [id])
  executions ReportExecution[]

  @@index([type])
  @@index([createdBy])
  @@map("reports")
}

model ReportExecution {
  id          String                @id @default(cuid())
  reportId    String
  status      ReportExecutionStatus @default(RUNNING)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  fileUrl     String?
  fileSize    Int?
  error       String?
  parameters  Json?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@map("report_executions")
}

// ============================================================================
// NOTIFICATIONS & COMMUNICATION
// ============================================================================

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  isRead    Boolean              @default(false)
  actionUrl String?
  metadata  Json?

  // Delivery
  channels NotificationChannel[]
  sentAt   DateTime?
  readAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

model EmployeeNotification {
  id        String               @id @default(cuid())
  title     String
  message   String
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  isRead    Boolean              @default(false)
  actionUrl String?
  metadata  Json?

  // Delivery
  channels NotificationChannel[]
  sentAt   DateTime?
  readAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Employee? @relation(fields: [employeeId], references: [id])
  employeeId String?

  @@index([isRead])
  @@index([type])
  @@map("employee_notifications")
}

model NotificationTemplate {
  id        String           @id @default(cuid())
  name      String           @unique
  subject   String
  body      String
  type      NotificationType
  variables String[]
  isActive  Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

// ============================================================================
// INTEGRATIONS & API
// ============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  permissions String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Webhook {
  id            String    @id @default(cuid())
  url           String
  events        String[]
  secret        String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id          String                @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int                   @default(0)
  lastAttempt DateTime?
  response    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@map("webhook_deliveries")
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model ContentPage {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_pages")
}

model Testimonial {
  id          String  @id @default(cuid())
  name        String
  company     String?
  position    String?
  content     String
  rating      Int? // 1-5
  avatar      String?
  isPublished Boolean @default(false)
  featured    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model FaqItem {
  id          String  @id @default(cuid())
  question    String
  answer      String
  category    String?
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?
  content       String
  featuredImage String?
  tags          String[]
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

// ============================================================================
// SYSTEM SETTINGS
// ============================================================================

model Setting {
  id       String  @id @default(cuid())
  key      String  @unique
  value    String
  type     String  @default("string")
  category String  @default("general")
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("settings")
}

model Currency {
  id       String  @id @default(cuid())
  code     String  @unique // ZAR, USD, EUR
  name     String
  symbol   String
  rate     Decimal @db.Decimal(10, 6) // Exchange rate to base currency
  isBase   Boolean @default(false)
  isActive Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("currencies")
}

model TaxRate {
  id          String  @id @default(cuid())
  name        String
  rate        Decimal @db.Decimal(5, 4)
  type        TaxType
  description String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)

  // Applicability
  country String? @default("ZA")
  region  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

