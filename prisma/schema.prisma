// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE USER MANAGEMENT
// ============================================================================

model User {
  id          String     @id @default(cuid())
  userId      String     @unique
  email       String     @unique
  name        String
  userName    String     @unique
  phone       String?
  avatar      String?
  role        UserRole   @default(VIEWER)
  status      UserStatus @default(ACTIVE)
  lastLogin   DateTime?
  timezone    String     @default("Africa/Johannesburg")
  language    String     @default("en")
  preferences Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Only this relation matters for being a manager
  managedDepartments Department[]  @relation("DepartmentManager")
  projectTeams       ProjectTeam[]

  permissions UserPermission[]

  // Everything else is unrelated
  createdTransactions Transaction[]
  createdInvoices     Invoice[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  createdReports      Report[]
  apiKeys             ApiKey[]
  sessions            Session[]
  passwordResets      PasswordReset[]
  createdQuotations   Quotation[]
  GeneralSetting      GeneralSetting[]
  Project             Project[]
  ChatSession         ChatSession[]
  Order               Order[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GeneralSetting {
  id           String  @id @default(cuid())
  userId       String
  companyName  String
  taxId        String
  phone        String
  phone2       String?
  phone3       String?
  website      String?
  paymentTerms String?
  note         String?
  bankAccount  String?
  bankAccount2 String?
  bankName     String?
  bankName2    String?
  logo         String?
  email        String
  Address      String
  city         String
  province     String
  postCode     String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("GeneralSettings")
}

model HRSettings {
  id String @id @default(cuid())

  // Payroll Settings
  paymentDay         Int     @default(25) // 1-31
  paymentMonth       String  @default("CURRENT") // "CURRENT" or "FOLLOWING"
  autoProcessPayroll Boolean @default(false)

  // Attendance Settings
  lateThreshold       Int   @default(15) // minutes
  halfDayThreshold    Float @default(4.0) // hours
  overtimeThreshold   Float @default(8.0) // hours
  workingDaysPerMonth Int   @default(22)

  // Leave Settings
  annualLeaveDays    Int     @default(21)
  sickLeaveDays      Int     @default(30)
  studyLeaveDays     Int     @default(5)
  maternityLeaveDays Int     @default(120)
  paternityLeaveDays Int     @default(10)
  carryOverEnabled   Boolean @default(true)
  maxCarryOverDays   Int     @default(5)

  // Company Settings
  workingHoursPerDay Int   @default(8)
  overtimeHourRate   Float @default(50.00)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([id])
  @@map("hr_settings")
}

model POSSetting {
  id String @id @default(cuid())

  // VAT Settings
  vatEnabled Boolean @default(true)
  vatRate    Float   @default(0.15) // 15% default VAT

  // Delivery Settings
  deliveryEnabled   Boolean @default(true)
  deliveryFee       Float   @default(50.00)
  freeDeliveryAbove Float   @default(500.00)

  // Discount Settings
  discountEnabled Boolean @default(true)
  maxDiscountRate Float   @default(20.00)

  // Receipt Settings
  receiptHeader      String?
  receiptFooter      String?
  printAutomatically Boolean @default(false)
  emailReceipt       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================================
// ORGANIZATION STRUCTURE
// ============================================================================

model Department {
  id          String           @id @default(cuid())
  name        String
  description String?
  code        String           @unique
  managerId   String?
  parentId    String?
  status      DepartmentStatus @default(ACTIVE)
  currency    String           @default("ZAR")

  // Location
  location String?
  floor    String?
  building String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  updater String?

  // Relations
  manager   User?         @relation("DepartmentManager", fields: [managerId], references: [id])
  parent    Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[]  @relation("DepartmentHierarchy")
  employees Employee[]    @relation("DepartmentEmployees")
  targets   Target[]
  budgets   Budget[]
  expenses  Transaction[]
  Quotation Quotation[]
  Invoice   Invoice[]

  @@map("departments")
}

model Employee {
  id              String         @id @default(cuid())
  employeeNumber  String         @unique
  firstName       String
  lastName        String
  email           String?        @unique
  phone           String?
  avatar          String?
  position        String
  departmentId    String?
  salary          Decimal        @db.Decimal(15, 2)
  currency        String         @default("ZAR")
  hireDate        DateTime
  terminationDate DateTime?
  status          EmployeeStatus @default(ACTIVE)

  // Personal Information
  idNumber      String?
  taxNumber     String?
  nationality   String?
  maritalStatus MaritalStatus?

  // Address Information
  address    String?
  city       String?
  province   String?
  postalCode String?
  country    String  @default("South Africa")

  // Emergency Contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  emergencyAddress  String?

  // Banking Information
  bankName      String?
  accountNumber String?
  branchCode    String?
  accountType   String?

  // Employment Details
  contractType ContractType?
  workSchedule String?
  probationEnd DateTime?

  scheduledKnockIn  String?
  scheduledKnockOut String?
  workingDays       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?

  // Leave Allocations
  annualLeaveDays    Int @default(21)
  sickLeaveDays      Int @default(30)
  studyLeaveDays     Int @default(5)
  maternityLeaveDays Int @default(120)
  paternityLeaveDays Int @default(10)
  unpaidLeaveDays    Int @default(0)

  // Relations
  department       Department?        @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  assignedTasks    Task[]             @relation(name: "TaskAssignments")
  payments         Payment[]
  documents        Document[]
  targets          Target[]
  kpiResults       KpiResult[]
  timeEntries      TimeEntry[]
  leaveRequests    LeaveRequest[]
  Note             Note[]
  AttendanceRecord AttendanceRecord[]
  Warning          Warning[]

  @@index([departmentId])
  @@index([status])
  @@map("employees")
}

model AttendanceRecord {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  date       DateTime  @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  breakStart DateTime?
  breakEnd   DateTime?

  // GPS Data
  checkInLat      Decimal? @db.Decimal(10, 8)
  checkInLng      Decimal? @db.Decimal(11, 8)
  checkOutLat     Decimal? @db.Decimal(10, 8)
  checkOutLng     Decimal? @db.Decimal(11, 8)
  checkInAddress  String?
  checkOutAddress String?

  // Check-in Method
  checkInMethod CheckInMethod? @default(MANUAL)

  // Scheduled Times 
  scheduledKnockIn  String?
  scheduledKnockOut String?

  // Calculated Fields
  regularHours  Decimal?         @db.Decimal(4, 2)
  overtimeHours Decimal?         @db.Decimal(4, 2)
  breakDuration Int?
  status        AttendanceStatus @default(PRESENT)
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@map("attendance_records")
}

model Warning {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  type            String
  severity        String
  reason          String
  actionPlan      String?
  date            DateTime  @default(now())
  status          String    @default("ACTIVE")
  resolvedAt      DateTime?
  resolutionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("warnings")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  leaveType     LeaveType
  startDate     DateTime
  endDate       DateTime
  days          Int
  reason        String
  contactInfo   String?
  status        LeaveStatus @default(PENDING)
  requestedDate DateTime    @default(now())
  approvedBy    String?
  approvedDate  DateTime?
  rejectedBy    String?
  rejectedDate  DateTime?
  comments      String?

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model Account {
  id            String      @id @default(cuid())
  name          String
  accountNumber String      @unique
  type          AccountType
  subType       String?
  balance       Decimal     @db.Decimal(15, 2)
  currency      String      @default("ZAR")
  bankName      String?
  branchCode    String?
  isActive      Boolean     @default(true)
  isDefault     Boolean     @default(false)

  // Reconciliation
  lastReconciledAt  DateTime?
  reconciledBalance Decimal?  @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  fromTransfers Transfer[]    @relation(name: "FromTransfers")
  toTransfers   Transfer[]    @relation(name: "ToTransfers")
  transactions  Transaction[]

  @@map("accounts")
}

model Transaction {
  id          String            @id @default(cuid())
  amount      Decimal           @db.Decimal(15, 2)
  currency    String            @default("ZAR")
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String
  reference   String?
  date        DateTime
  method      PaymentMethod?

  // Relations
  invoiceId    String?
  categoryId   String?
  clientId     String?
  departmentId String?
  createdBy    String

  // Additional Information
  taxAmount     Decimal? @db.Decimal(15, 2)
  taxRate       Decimal? @db.Decimal(5, 4)
  netAmount     Decimal? @db.Decimal(15, 2)
  vendor        String?
  receiptUrl    String?
  invoiceNumber String?

  // Reconciliation
  isReconciled Boolean   @default(false)
  reconciledAt DateTime?
  reconciledBy String?

  // Multi-currency
  exchangeRate Decimal? @db.Decimal(10, 6)
  baseCurrency String?
  baseAmount   Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoice    Invoice?           @relation(fields: [invoiceId], references: [id])
  category   Category?          @relation(fields: [categoryId], references: [id])
  client     Client?            @relation(fields: [clientId], references: [id])
  department Department?        @relation(fields: [departmentId], references: [id])
  creator    User               @relation(fields: [createdBy], references: [id])
  documents  Document[]
  splits     TransactionSplit[]
  Payment    Payment[]
  Account    Account?           @relation(fields: [accountId], references: [id])
  accountId  String?
  Note       Note[]
  Payroll    Payroll?
  Refund     Refund[]

  @@index([invoiceId])
  @@index([categoryId])
  @@index([clientId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@map("transactions")
}

model TransactionCeo {
  id            String            @id @default(cuid())
  amount        Decimal           @db.Decimal(15, 2)
  currency      String            @default("ZAR")
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  description   String
  reference     String?
  date          DateTime
  method        PaymentMethod?
  categoryCeoId String?

  // Additional Information
  vendor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  CategoryCeo CategoryCeo? @relation(fields: [categoryCeoId], references: [id])

  @@map("transactionsCeo")
}

model TransactionSplit {
  id            String   @id @default(cuid())
  transactionId String
  categoryId    String
  amount        Decimal  @db.Decimal(15, 2)
  description   String?
  percentage    Decimal? @db.Decimal(5, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id])

  @@map("transaction_splits")
}

model Payroll {
  id          String        @id @default(cuid())
  month       String
  description String?
  type        PaymentType
  totalAmount Float
  currency    String        @default("ZAR")
  status      PayrollStatus @default(PROCESSED)

  baseAmount     Float
  overtimeAmount Float

  // Relationships
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String      @unique

  payments Payment[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("payrolls")
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

model Transfer {
  id            String         @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amount        Decimal        @db.Decimal(15, 2)
  currency      String         @default("ZAR")
  exchangeRate  Decimal?       @db.Decimal(10, 6)
  fee           Decimal?       @db.Decimal(15, 2)
  description   String?
  reference     String?
  status        TransferStatus @default(PENDING)
  transferDate  DateTime
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromAccount Account @relation(name: "FromTransfers", fields: [fromAccountId], references: [id])
  toAccount   Account @relation(name: "ToTransfers", fields: [toAccountId], references: [id])

  @@map("transfers")
}

model Category {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String?
  icon        String?
  type        CategoryType
  parentId    String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)

  // Tax Information
  taxDeductible Boolean @default(false)
  taxCategory   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  parent       Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]         @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      BudgetItem[]
  splits       TransactionSplit[]

  @@map("categories")
}

model CategoryCeo {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String?
  icon        String?
  type        CategoryType
  parentId    String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)

  // Tax Information
  taxDeductible Boolean @default(false)
  taxCategory   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  transactions TransactionCeo[]

  @@map("categoriesCeo")
}

// ============================================================================
// CLIENT MANAGEMENT
// ============================================================================

model Client {
  id           String       @id @default(cuid())
  clientNumber String       @unique
  name         String
  email        String       @unique
  phone        String       @unique
  company      String?
  avatar       String?
  status       ClientStatus @default(ACTIVE)
  type         ClientType   @default(INDIVIDUAL)

  // Business Information
  taxNumber String?
  vatNumber String?
  website   String?
  industry  String?

  // Address Information
  billingAddress Json?
  address        String?

  // Financial Information
  creditLimit  Decimal? @db.Decimal(15, 2)
  paymentTerms Int? // Days
  currency     String   @default("ZAR")

  // Relationship
  assignedTo String?
  source     String?
  notes      String?
  createdBy  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoices     Invoice[]
  transactions Transaction[]
  documents    Document[]
  projects     Project[]
  quotations   Quotation[]
  Note         Note[]
  toolRentals  ToolRental[]

  @@index([status])
  @@index([type])
  @@map("clients")
}

model Project {
  id            String        @id @default(cuid())
  projectNumber String
  title         String
  description   String?
  clientId      String?
  managerId     String
  status        ProjectStatus @default(PLANNING)
  priority      Priority      @default(MEDIUM)
  starred       Boolean       @default(false)
  archived      Boolean       @default(false)

  // Timeline
  startDate DateTime?
  endDate   DateTime?
  deadline  DateTime?

  // Financial
  budget      Decimal? @db.Decimal(15, 2)
  budgetSpent Decimal? @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  hourlyRate  Decimal? @db.Decimal(10, 2)

  // Progress
  progress Int @default(0) // 0-100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client      Client?       @relation(fields: [clientId], references: [id])
  manager     User?         @relation(fields: [managerId], references: [id])
  teamMembers ProjectTeam[]

  tasks         Task[]
  timeEntries   TimeEntry[]
  invoices      Invoice[]
  quotations    Quotation[]
  documents     Document[]
  Note          Note[]
  Folder        Folder[]
  comment       comment[]
  toolInterUses ToolInterUse[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

model ProjectTeam {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String?

  // Permissions
  canEditTask      Boolean @default(false)
  canDeleteTask    Boolean @default(false)
  canDeleteFiles   Boolean @default(false)
  canCreateTask    Boolean @default(false)
  canAddInvoice    Boolean @default(false)
  canUploadFiles   Boolean @default(false)
  canEditFile      Boolean @default(false)
  canViewFinancial Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_teams")
}

model Task {
  id            String     @id @default(cuid())
  taskNumber    String
  title         String
  description   String?
  projectId     String
  status        TaskStatus @default(TODO)
  priority      Priority   @default(MEDIUM)
  noteId        String?
  isAIGenerated Boolean    @default(false)

  // Timeline
  dueDate     DateTime?
  completedAt DateTime?

  // Estimation
  estimatedHours Decimal? @db.Decimal(8, 2)
  actualHours    Decimal? @db.Decimal(8, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignees Employee[] @relation("TaskAssignments")
  comment   comment[]
  documents Document[]

  timeEntries TimeEntry[]
  Subtask     Subtask[]

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

model Subtask {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  estimatedHours Float?
  order          Int
  taskId         String
  task           Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Document {
  id           String       @id @default(cuid())
  name         String
  originalName String?
  type         DocumentType
  url          String
  size         Int?
  mimeType     String?
  checksum     String?

  // Relations (polymorphic)
  employeeId    String?
  clientId      String?
  transactionId String?
  projectId     String?

  folderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  Project Project? @relation(fields: [projectId], references: [id])
  folder  Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  Task    Task?    @relation(fields: [taskId], references: [id])
  taskId  String?

  @@index([type])
  @@index([employeeId])
  @@index([clientId])
  @@index([transactionId])
  @@map("documents")
}

model comment {
  id      String @id @default(cuid())
  content String

  projectId       String?
  liked           Boolean @default(false)
  pinned          Boolean @default(false)
  commenterName   String
  commenterId     String
  commenterAvatar String?
  commenterRole   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  commentReply commentReply[]
  Task         Task?          @relation(fields: [taskId], references: [id])
  taskId       String?
}

model Note {
  id            String   @id @default(cuid())
  title         String
  content       String
  tags          String[]
  // Relations (polymorphic)
  employeeId    String?
  clientId      String?
  transactionId String?
  projectId     String?
  folderId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  Project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder      Folder?      @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([clientId])
  @@index([transactionId])
}

model commentReply {
  id        String  @id @default(cuid())
  content   String
  commentId String
  liked     Boolean @default(false)

  commenterName   String
  commenterId     String
  commenterAvatar String?
  commenterRole   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comment   comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Folder {
  id    String @id @default(cuid())
  title String

  // Relations (polymorphic)
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Project  Project?   @relation(fields: [projectId], references: [id])
  Note     Note[]
  Document Document[]

  @@index([projectId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  employeeId  String
  projectId   String?
  taskId      String?
  description String?
  hours       Decimal  @db.Decimal(8, 2)
  hourlyRate  Decimal? @db.Decimal(10, 2)
  date        DateTime
  billable    Boolean  @default(true)
  invoiced    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  task     Task?    @relation(fields: [taskId], references: [id])

  @@index([employeeId])
  @@index([projectId])
  @@index([date])
  @@map("time_entries")
}

// ============================================================================
// BUDGET MANAGEMENT
// ============================================================================

model Budget {
  id           String       @id @default(cuid())
  name         String
  description  String?
  totalAmount  Decimal      @db.Decimal(15, 2)
  currency     String       @default("ZAR")
  startDate    DateTime
  endDate      DateTime
  status       BudgetStatus @default(ACTIVE)
  departmentId String?

  // Approval
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  department Department?   @relation(fields: [departmentId], references: [id])
  items      BudgetItem[]
  alerts     BudgetAlert[]

  @@index([departmentId])
  @@index([status])
  @@map("budgets")
}

model BudgetItem {
  id         String  @id @default(cuid())
  budgetId   String
  categoryId String
  amount     Decimal @db.Decimal(15, 2)
  spent      Decimal @default(0) @db.Decimal(15, 2)
  currency   String  @default("ZAR")
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([budgetId, categoryId])
  @@map("budget_items")
}

model BudgetAlert {
  id          String          @id @default(cuid())
  budgetId    String
  type        BudgetAlertType
  threshold   Decimal         @db.Decimal(5, 2) // Percentage
  triggered   Boolean         @default(false)
  triggeredAt DateTime?
  message     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("budget_alerts")
}

// ============================================================================
// INVOICE MANAGEMENT
// ============================================================================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  project       String?
  amount        Decimal       @db.Decimal(15, 2)
  currency      String        @default("ZAR")
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime
  dueDate       DateTime
  paidDate      DateTime?

  // Invoice Details
  description    String?
  taxAmount      Decimal?      @db.Decimal(15, 2)
  taxRate        Decimal?      @db.Decimal(5, 4)
  discountAmount Decimal?      @db.Decimal(15, 2)
  discountType   DiscountType? @default(AMOUNT)
  totalAmount    Decimal       @db.Decimal(15, 2)

  // Terms
  paymentTerms String?
  notes        String?

  // Relations
  createdBy String

  // Recurring
  isRecurring Boolean @default(false)
  recurringId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client            @relation(fields: [clientId], references: [id])
  creator      User              @relation(fields: [createdBy], references: [id])
  items        InvoiceItem[]
  payments     InvoicePayment[]
  recurring    RecurringInvoice? @relation(fields: [recurringId], references: [id])
  Project      Project?          @relation(fields: [projectId], references: [id])
  projectId    String?
  Department   Department?       @relation(fields: [departmentId], references: [id])
  departmentId String?
  Transaction  Transaction[]
  toolRentals  ToolRental[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  taxRate     Decimal? @db.Decimal(5, 4)
  taxAmount   Decimal? @db.Decimal(15, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model InvoicePayment {
  id        String               @id @default(cuid())
  invoiceId String
  amount    Decimal              @db.Decimal(15, 2)
  currency  String               @default("ZAR")
  method    PaymentMethod
  reference String?
  notes     String?
  status    InvoicePaymentStatus @default(PENDING)
  paidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_payments")
}

model RecurringInvoice {
  id        String             @id @default(cuid())
  clientId  String
  frequency RecurringFrequency
  interval  Int                @default(1)
  startDate DateTime
  endDate   DateTime?
  nextDate  DateTime
  isActive  Boolean            @default(true)

  // Template
  template Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@map("recurring_invoices")
}

// ============================================================================
// QUOTATION MANAGEMENT
// ============================================================================

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  clientId        String
  projectId       String?
  amount          Decimal         @db.Decimal(15, 2)
  currency        String          @default("ZAR")
  status          QuotationStatus @default(DRAFT)
  issueDate       DateTime
  validUntil      DateTime
  acceptedDate    DateTime?
  rejectedDate    DateTime?

  // Quotation Details
  title          String?
  description    String?
  taxAmount      Decimal?      @db.Decimal(15, 2)
  taxRate        Decimal?      @db.Decimal(5, 4)
  discountAmount Decimal?      @db.Decimal(15, 2)
  discountType   DiscountType? @default(AMOUNT)
  totalAmount    Decimal       @db.Decimal(15, 2)

  // Terms and Conditions
  terms         String?
  notes         String?
  paymentTerms  String?
  deliveryTerms String?

  // Conversion
  convertedToInvoice Boolean @default(false)
  invoiceId          String?

  // Relations
  createdBy String

  // Follow-up
  followUpDate DateTime?
  reminderSent Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client   @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  creator User     @relation(fields: [createdBy], references: [id])

  items        QuotationItem[]
  Department   Department?     @relation(fields: [departmentId], references: [id])
  departmentId String?
  toolRentals  ToolRental[]

  @@index([clientId])
  @@index([status])
  @@index([validUntil])
  @@index([createdBy])
  @@map("quotations")
}

model QuotationItem {
  id          String   @id @default(cuid())
  quotationId String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  taxRate     Decimal? @db.Decimal(5, 4)
  taxAmount   Decimal? @db.Decimal(15, 2)
  notes       String?
  sortOrder   Int      @default(0)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

/**
 * model QuotationRevision {
 * id          String  @id @default(cuid())
 * quotationId String
 * version     Int
 * changes     Json
 * reason      String?
 * createdBy   String
 * createdAt DateTime @default(now())
 * quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
 * @@unique([quotationId, version])
 * @@map("quotation_revisions")
 * }
 * model QuotationActivity {
 * id          String                @id @default(cuid())
 * quotationId String
 * type        QuotationActivityType
 * description String
 * metadata    Json?
 * createdBy   String?
 * createdAt DateTime @default(now())
 * quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
 * @@index([quotationId])
 * @@map("quotation_activities")
 * }
 * model QuotationTemplate {
 * id          String  @id @default(cuid())
 * name        String
 * description String?
 * template    Json
 * isDefault   Boolean @default(false)
 * isActive    Boolean @default(true)
 * category    String?
 * createdBy String
 * createdAt DateTime @default(now())
 * updatedAt DateTime @updatedAt
 * @@map("quotation_templates")
 * }
 */

// ============================================================================
// PAYROLL MANAGEMENT
// ============================================================================
model Product {
  id        String   @id @default(uuid())
  category  String
  size      String
  price     Decimal
  panels    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model ProductCategory {
  id          String        @id @default(cuid())
  name        String        @unique
  description String?
  products    ShopProduct[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("Productcategories")
}

model ShopProduct {
  id          String  @id @default(cuid())
  name        String
  description String?
  sku         String  @unique
  category    String

  // Pricing
  price     Decimal  @db.Decimal(10, 2)
  costPrice Decimal? @db.Decimal(10, 2)

  // Inventory
  stock    Int  @default(0)
  minStock Int  @default(0)
  maxStock Int?

  // Product Details
  weight     Decimal? @db.Decimal(8, 3)
  dimensions String?
  color      String?
  size       String?
  brand      String?

  // Status
  status   ProductStatus @default(ACTIVE)
  featured Boolean       @default(false)

  // Images
  images Json? // Array of image URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creater String?

  // Relations
  orderItems        OrderItem[]
  stockMovements    StockMovement[]
  saleItems         SaleItem[]
  productDocuments  ProductDocument[]
  ProductCategory   ProductCategory?  @relation(fields: [productCategoryId], references: [id])
  productCategoryId String?

  @@map("shopProducts")
}

model StockMovement {
  id            String            @id @default(cuid())
  shopProductId String
  type          StockMovementType
  quantity      Int
  reason        String?
  reference     String?
  previousStock Int
  newStock      Int
  createdAt     DateTime          @default(now())

  creater String?

  shopProduct ShopProduct @relation(fields: [shopProductId], references: [id])

  @@map("stock_movements")
}

model ProductDocument {
  id            String       @id @default(cuid())
  name          String
  url           String
  type          DocumentType
  size          Int
  mimeType      String
  shopProductId String
  shopProduct   ShopProduct  @relation(fields: [shopProductId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  @@map("product_documents")
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  saleId      String @unique
  sale        Sale   @relation(fields: [saleId], references: [id])

  // Order Details
  status       OrderStatus @default(PENDING)
  deliveryDate DateTime?
  assignedTo   String? // Staff assigned for delivery

  // Tracking
  carrier        String?
  trackingNumber String?

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  User       User?       @relation(fields: [userId], references: [id])
  userId     String?
  OrderItem  OrderItem[]
  Customer   Customer?   @relation(fields: [customerId], references: [id])
  customerId String?

  @@map("orders")
}

model Sale {
  id         String    @id @default(cuid())
  saleNumber String    @unique
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Customer info for walk-in customers
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerAddress String?

  // Sale Details
  status SaleStatus @default(COMPLETED)

  // Delivery Information
  isDelivery           Boolean @default(false)
  deliveryFee          Float   @default(0)
  deliveryAddress      String?
  deliveryInstructions String?

  // Amounts
  subtotal        Float
  tax             Float @default(0)
  discount        Float @default(0)
  discountPercent Float @default(0)
  deliveryAmount  Float @default(0)
  total           Float

  refundedAmount Decimal @default(0) @db.Decimal(10, 2)
  refundedTax    Decimal @default(0) @db.Decimal(10, 2)

  // Payment
  paymentStatus  ShopPaymentStatus @default(COMPLETED)
  paymentMethod  PaymentMethod
  amountReceived Float?
  change         Float?

  // Receipt
  receiptSent  Boolean @default(false)
  receiptEmail String?

  // Dates
  saleDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String

  // Relations
  items   SaleItem[]
  orderId String?
  Order   Order?
  Refund  Refund[]

  @@map("sales")
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  shopProductId String
  ShopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity   Int
  price      Decimal      @db.Decimal(10, 2)
  total      Decimal      @db.Decimal(10, 2)
  RefundItem RefundItem[]

  @@map("sale_items")
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id])
  shopProductId String
  ShopProduct   ShopProduct @relation(fields: [shopProductId], references: [id])

  quantity Int
  price    Float
  total    Float

  @@map("order_items")
}

model Refund {
  id           String @id @default(cuid())
  refundNumber String @unique
  saleId       String
  sale         Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  // Refund Details
  status    RefundStatus @default(PENDING)
  reason    String
  method    RefundMethod
  amount    Float
  taxAmount Float        @default(0)

  // Items being refunded
  items RefundItem[]

  // Approval workflow
  requestedBy     String
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  // Completion
  processedBy String?
  processedAt DateTime?

  // Relations
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactionId String?

  @@map("refunds")
}

model RefundItem {
  id       String @id @default(cuid())
  refundId String
  refund   Refund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  saleItemId String
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id])

  quantity  Int
  price     Float
  total     Float
  taxAmount Float @default(0)

  @@map("refund_items")
}

model Customer {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String  @unique
  phone     String?

  // Address
  address    String?
  city       String?
  province   Province?
  postalCode String?
  country    String    @default("South Africa")

  // Customer Details
  dateOfBirth DateTime? @db.Date
  gender      Gender?

  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders Order[]
  sales  Sale[]

  @@map("customers")
}

model Payment {
  id          String        @id @default(cuid())
  employeeId  String
  amount      Decimal       @db.Decimal(15, 2)
  currency    String        @default("ZAR")
  type        PaymentType
  description String?
  payDate     DateTime
  status      PaymentStatus @default(PAID)

  baseAmount     Decimal @db.Decimal(15, 2)
  overtimeAmount Decimal @db.Decimal(15, 2)

  overtimeHours Decimal? @db.Decimal(4, 2)
  regularHours  Decimal? @db.Decimal(4, 2)
  daysWorked    Int

  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionId String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  employee  Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  Payroll   Payroll? @relation(fields: [payrollId], references: [id])
  payrollId String?

  @@index([employeeId])
  @@index([payDate])
  @@map("payments")
}

model ChatSession {
  id        String   @id @default(cuid())
  title     String
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model Tool {
  id          String  @id @default(cuid())
  name        String
  description String?
  category    String?
  canBeRented Boolean @default(true)

  // Pricing & Rental Rates
  purchasePrice     Decimal   @db.Decimal(12, 2)
  purchaseDate      DateTime? @db.Date
  rentalRateDaily   Decimal?  @db.Decimal(10, 2)
  rentalRateWeekly  Decimal?  @db.Decimal(10, 2)
  rentalRateMonthly Decimal?  @db.Decimal(10, 2)

  // Status & Condition
  status    ToolStatus    @default(AVAILABLE)
  condition ToolCondition @default(GOOD)

  // Images
  primaryImage String?

  // System
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  images Json?

  rentals         ToolRental[]
  InterUse        ToolInterUse[]
  maintenanceLogs ToolMaintenanceLog[]
  rentalRequests  RentalRequest[]

  @@map("tools")
}

model ToolRental {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Renter Information
  businessName  String
  renterContact String?
  renterEmail   String?
  renterPhone   String?

  // Rental Period
  rentalStartDate DateTime @db.Date
  rentalEndDate   DateTime @db.Date

  // Payment
  rentalRate Decimal  @db.Decimal(10, 2)
  rentalDays Int?
  totalCost  Decimal? @db.Decimal(10, 2)

  // Payment Status
  paymentStatus   PaymentStatus @default(PENDING)
  amountPaid      Decimal       @default(0) @db.Decimal(10, 2)
  remainingAmount Decimal?      @db.Decimal(10, 2)
  paidDate        DateTime?     @db.Date

  // Status
  status RentalStatus @default(ACTIVE)

  // Additional Info
  notes             String?
  returnCondition   String?
  damageReported    Boolean @default(false)
  damageDescription String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  quotation   Quotation? @relation(fields: [quotationId], references: [id])
  quotationId String?
  invoice     Invoice?   @relation(fields: [invoiceId], references: [id])
  invoiceId   String?
  client      Client?    @relation(fields: [clientId], references: [id])
  clientId    String?

  @@map("tool_rentals")
}

model ToolInterUse {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  // Rental Period
  useStartDate DateTime @db.Date
  useEndDate   DateTime @db.Date

  // Status
  status ToolInterUseStatus @default(ACTIVE)

  // Additional Info
  notes             String?
  damageReported    Boolean @default(false)
  damageDescription String?
  relisedBy         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Project   Project? @relation(fields: [projectId], references: [id])
  projectId String?

  @@map("tool_interUses")
}

model ToolMaintenanceLog {
  id     String @id @default(cuid())
  toolId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  maintenanceType String
  cost            Decimal  @db.Decimal(10, 2)
  maintenanceDate DateTime @db.Date
  notes           String?
  assignedTo      String?
  processedBy     String?

  createdAt DateTime @default(now())

  @@map("tool_maintenance_logs")
}

model RentalRequest {
  id     String  @id @default(cuid())
  toolId String?
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: SetNull)

  // Requester Information
  requesterName     String
  requesterEmail    String
  requesterPhone    String?
  requesterBusiness String

  // Rental Details
  requestedStartDate DateTime @db.Date
  requestedEndDate   DateTime @db.Date
  rentalDays         Int?
  estimatedCost      Decimal? @db.Decimal(10, 2)

  // Request Status
  status   RequestStatus @default(PENDING)
  priority Priority      @default(MEDIUM)

  // Approval
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?

  // Additional Info
  purpose             String?
  specialRequirements String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_requests")
}

// ============================================================================
// TARGETS & KPI MANAGEMENT
// ============================================================================

model Target {
  id           String     @id @default(cuid())
  name         String
  description  String?
  type         TargetType
  category     String?
  targetValue  Decimal    @db.Decimal(15, 2)
  currentValue Decimal    @default(0) @db.Decimal(15, 2)
  unit         String?
  currency     String?    @default("ZAR")

  // Timeline
  startDate DateTime
  endDate   DateTime

  // Assignment
  employeeId   String?
  departmentId String?

  // Status
  status   TargetStatus @default(ACTIVE)
  priority Priority     @default(MEDIUM)

  // Progress
  progress Decimal @default(0) @db.Decimal(5, 2) // Percentage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  employee   Employee?      @relation(fields: [employeeId], references: [id])
  department Department?    @relation(fields: [departmentId], references: [id])
  updates    TargetUpdate[]
  kpis       Kpi[]

  @@index([employeeId])
  @@index([departmentId])
  @@index([status])
  @@map("targets")
}

model TargetUpdate {
  id        String  @id @default(cuid())
  targetId  String
  value     Decimal @db.Decimal(15, 2)
  notes     String?
  updatedBy String?

  createdAt DateTime @default(now())

  target Target @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@map("target_updates")
}

model Kpi {
  id          String       @id @default(cuid())
  name        String
  description String?
  formula     String?
  unit        String?
  targetId    String?
  frequency   KpiFrequency @default(MONTHLY)
  isActive    Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  target  Target?     @relation(fields: [targetId], references: [id])
  results KpiResult[]

  @@map("kpis")
}

model KpiResult {
  id         String   @id @default(cuid())
  kpiId      String
  employeeId String?
  value      Decimal  @db.Decimal(15, 2)
  period     DateTime
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kpi      Kpi       @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@unique([kpiId, employeeId, period])
  @@index([kpiId])
  @@index([period])
  @@map("kpi_results")
}

// ============================================================================
// REPORTING & ANALYTICS
// ============================================================================

model Report {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        ReportType
  config      Json
  schedule    Json?
  isScheduled Boolean    @default(false)
  isPublic    Boolean    @default(false)

  // Generation
  lastRunAt DateTime?
  nextRunAt DateTime?
  status    ReportStatus @default(DRAFT)

  // Relations
  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator    User              @relation(fields: [createdBy], references: [id])
  executions ReportExecution[]

  @@index([type])
  @@index([createdBy])
  @@map("reports")
}

model ReportExecution {
  id          String                @id @default(cuid())
  reportId    String
  status      ReportExecutionStatus @default(RUNNING)
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  fileUrl     String?
  fileSize    Int?
  error       String?
  parameters  Json?

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@map("report_executions")
}

// ============================================================================
// NOTIFICATIONS & COMMUNICATION
// ============================================================================

model Notification {
  id        String               @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType
  priority  NotificationPriority @default(MEDIUM)
  isRead    Boolean              @default(false)
  actionUrl String?
  metadata  Json?

  // Delivery
  channels NotificationChannel[]
  sentAt   DateTime?
  readAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@map("notifications")
}

model NotificationTemplate {
  id        String           @id @default(cuid())
  name      String           @unique
  subject   String
  body      String
  type      NotificationType
  variables String[]
  isActive  Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

// ============================================================================
// INTEGRATIONS & API
// ============================================================================

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  permissions String[]
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model Webhook {
  id            String    @id @default(cuid())
  url           String
  events        String[]
  secret        String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id          String                @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  status      WebhookDeliveryStatus @default(PENDING)
  attempts    Int                   @default(0)
  lastAttempt DateTime?
  response    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@map("webhook_deliveries")
}

// ============================================================================
// CONTENT MANAGEMENT
// ============================================================================

model ContentPage {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("content_pages")
}

model Testimonial {
  id          String  @id @default(cuid())
  name        String
  company     String?
  position    String?
  content     String
  rating      Int? // 1-5
  avatar      String?
  isPublished Boolean @default(false)
  featured    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model FaqItem {
  id          String  @id @default(cuid())
  question    String
  answer      String
  category    String?
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faq_items")
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String?
  content       String
  featuredImage String?
  tags          String[]
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?

  // SEO
  metaTitle       String?
  metaDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

// ============================================================================
// SYSTEM SETTINGS
// ============================================================================

model Setting {
  id       String  @id @default(cuid())
  key      String  @unique
  value    String
  type     String  @default("string")
  category String  @default("general")
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("settings")
}

model Currency {
  id       String  @id @default(cuid())
  code     String  @unique // ZAR, USD, EUR
  name     String
  symbol   String
  rate     Decimal @db.Decimal(10, 6) // Exchange rate to base currency
  isBase   Boolean @default(false)
  isActive Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("currencies")
}

model TaxRate {
  id          String  @id @default(cuid())
  name        String
  rate        Decimal @db.Decimal(5, 4)
  type        TaxType
  description String?
  isDefault   Boolean @default(false)
  isActive    Boolean @default(true)

  // Applicability
  country String? @default("ZA")
  region  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tax_rates")
}

