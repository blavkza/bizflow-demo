  interestRate3Months  Float?
  interestRate6Months  Float?
  interestRate9Months  Float?
  interestRate12Months Float?

  interestTiers LenderInterestTier[] // Dynamic tiered rates for FIXED_INTEREST

  createdBy String?
  documents Document[]
  creator   User?      @relation(fields: [createdBy], references: [id])
  loans     Loan[]

  @@map("lenders")
}

model LenderInterestTier {
  id           String   @id @default(cuid())
  lenderId     String
  lender       Lender   @relation(fields: [lenderId], references: [id], onDelete: Cascade)
  termMonths   Int // e.g. 3, 6, 9, 12, 18, 24...
  interestRate Float // The fixed interest rate for this term
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([lenderId, termMonths]) // Ensure unique tier per lender per term
  @@map("lender_interest_tiers")
}

model ToolRequest {
  id            String              @id @default(cuid())
  employeeId    String?
  freelancerId  String?
  type          String
  toolName      String
  description   String?
  priority      ToolRequestPriority @default(MEDIUM)
  status        ToolRequestStatus   @default(PENDING)
  notes         String?
  requestedDate DateTime            @default(now())
  resolvedDate  DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  reason        String?
  quantity      Int                 @default(1)
  resolvedById  String?
  employee      Employee?           @relation(fields: [employeeId], references: [id])
  freelancer    FreeLancer?         @relation(fields: [freelancerId], references: [id])
  traineeId     String?
  trainee       Trainee?            @relation(fields: [traineeId], references: [id])
  resolvedBy    User?               @relation("ResolvedRequests", fields: [resolvedById], references: [id])

  @@map("tool_requests")
}

model ToolReturn {
  id                String        @id @default(cuid())
  toolId            String
  employeeId        String?
  freelancerId      String?
  quantity          Int
  status            ToolStatus
  condition         ToolCondition
  damageDescription String?
  damageCost        Decimal?      @default(0) @db.Decimal(10, 2)
  returnedDate      DateTime      @default(now())
  processedById     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  adminNotes        String?
  isApproved        Boolean       @default(false)
  employee          Employee?     @relation(fields: [employeeId], references: [id])
  freelancer        FreeLancer?   @relation(fields: [freelancerId], references: [id])
  traineeId         String?
  trainee           Trainee?      @relation(fields: [traineeId], references: [id])
  processedBy       User?         @relation("ProcessedReturns", fields: [processedById], references: [id])
  tool              Tool          @relation(fields: [toolId], references: [id])

  @@map("tool_returns")
}

model ToolMaintenance {
  id               String              @id @default(cuid())
  toolId           String?
  toolName         String
  serialNumber     String?
  quantity         Int                 @default(1)
  issueDescription String?
  maintenanceType  String?
  cost             Decimal?            @default(0) @db.Decimal(10, 2)
  status           MaintenanceStatus   @default(PENDING)
  priority         MaintenancePriority @default(MEDIUM)
  startDate        DateTime?
  completionDate   DateTime?
  technician       String?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  reportedBy       String?
  tool             Tool?               @relation(fields: [toolId], references: [id])

  @@map("tool_maintenance")
}

model ToolCheck {
  id                String        @id @default(cuid())
  toolId            String
  employeeId        String?
  freelancerId      String?
  traineeId         String?
  checkDate         DateTime      @default(now())
  condition         ToolCondition
  isPresent         Boolean       @default(true)
  isLost            Boolean       @default(false)
  damageCost        Decimal?      @default(0) @db.Decimal(10, 2)
  damageDescription String?
  notes             String?
  checkedBy         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deductFromWorker  Boolean       @default(false)

  tool       Tool        @relation(fields: [toolId], references: [id])
  employee   Employee?   @relation(fields: [employeeId], references: [id])
  freelancer FreeLancer? @relation(fields: [freelancerId], references: [id])
  trainee    Trainee?    @relation(fields: [traineeId], references: [id])

  @@index([toolId])
  @@index([checkDate])
  @@map("tool_checks")
}

