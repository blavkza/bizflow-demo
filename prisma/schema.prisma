// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE USER MANAGEMENT
// ============================================================================

model User {
  id          String     @id @default(cuid())
  userId      String     @unique
  email       String     @unique
  name        String
  userName    String     @unique
  phone       String?
  avatar      String?
  role        UserRole   @default(VIEWER)
  status      UserStatus @default(ACTIVE)
  lastLogin   DateTime?
  timezone    String     @default("Africa/Johannesburg")
  language    String     @default("en")
  preferences Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userType   UserType  @default(ADMIN)
  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  managedDepartments Department[]  @relation("DepartmentManager")
  projectTeams       ProjectTeam[]

  permissions UserPermission[]

  createdTransactions Transaction[]
  createdInvoices     Invoice[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  createdReports      Report[]
  apiKeys             ApiKey[]
  sessions            Session[]
  passwordResets      PasswordReset[]
  createdQuotations   Quotation[]
  GeneralSetting      GeneralSetting[]
  Project             Project[]
  ChatSession         ChatSession[]
  Order               Order[]
  Vendor              Vendor[]
  Expense             Expense[]
  recurringInvoices   RecurringInvoice[]
  dashboardSettings   DashboardSettings?
  workLogs            WorkLog[]
  timeEntries         TimeEntry[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model GeneralSetting {
  id           String  @id @default(cuid())
  userId       String
  companyName  String
  taxId        String
  phone        String
  phone2       String?
  phone3       String?
  website      String?
  paymentTerms String?
  note         String?
  bankAccount  String?
  bankAccount2 String?
  bankName     String?
  bankName2    String?
  logo         String?
  email        String
  Address      String
  city         String
  province     String
  postCode     String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("GeneralSettings")
}

model HRSettings {
  id String @id @default(cuid())

  // Payroll Settings
  paymentDay         Int     @default(25) // 1-31
  paymentMonth       String  @default("CURRENT") // "CURRENT" or "FOLLOWING"
  autoProcessPayroll Boolean @default(false)

  // Attendance Settings
  lateThreshold       Int   @default(15) // minutes
  halfDayThreshold    Float @default(4.0) // hours
  overtimeThreshold   Float @default(8.0) // hours
  workingDaysPerMonth Int   @default(22)

  // Leave Settings
  annualLeaveDays    Int     @default(21)
  sickLeaveDays      Int     @default(30)
  studyLeaveDays     Int     @default(5)
  maternityLeaveDays Int     @default(120)
  paternityLeaveDays Int     @default(10)
  carryOverEnabled   Boolean @default(true)
  maxCarryOverDays   Int     @default(5)

  // Company Settings
  workingHoursPerDay Int   @default(8)
  overtimeHourRate   Float @default(50.00)

  // Bonus Settings
  annualBonusEnabled         Boolean @default(true)
  annualBonusType            String  @default("DECEMBER")
  annualBonusPercentage      Float   @default(100)
  performanceBonusEnabled    Boolean @default(true)
  performanceBonusType       String  @default("INDIVIDUAL")
  performanceBonusPercentage Float   @default(5)
  profitSharingEnabled       Boolean @default(false)
  profitSharingPercentage    Float   @default(10)
  thirteenthChequeEnabled    Boolean @default(false)
  spotBonusEnabled           Boolean @default(true)
  spotBonusAmount            Float   @default(500)
  meritBonusEnabled          Boolean @default(true)
  meritBonusPercentage       Float   @default(3)
  appreciationBonusEnabled   Boolean @default(true)
  appreciationBonusAmount    Float   @default(250)
  incentivePaymentEnabled    Boolean @default(true)
  incentivePaymentPercentage Float   @default(4)
  recognitionAwardEnabled    Boolean @default(true)
  recognitionAwardAmount     Float   @default(300)
  attendanceBonusEnabled     Boolean @default(true)
  attendanceBonusPercentage  Float   @default(2)
  overtimeBonusEnabled       Boolean @default(true)
  overtimeBonusPercentage    Float   @default(10)

  // Deduction Settings
  uniformPPEEnabled         Boolean @default(true)
  uniformPPEMaxDeduction    Float   @default(500)
  damageLossEnabled         Boolean @default(true)
  damageLossMaxPercentage   Float   @default(20)
  uifEnabled                Boolean @default(true)
  uifPercentage             Float   @default(1)
  pensionEnabled            Boolean @default(true)
  pensionPercentage         Float   @default(7.5)
  medicalAidEnabled         Boolean @default(true)
  medicalAidMaxDeduction    Float   @default(2000)
  taxEnabled                Boolean @default(true)
  taxTableYear              String  @default("2025")
  overpaymentEnabled        Boolean @default(true)
  overpaymentMaxPercentage  Float   @default(25)
  loanRepaymentEnabled      Boolean @default(true)
  funeralBenefitEnabled     Boolean @default(true)
  funeralBenefitAmount      Float   @default(100)
  tradeUnionEnabled         Boolean @default(false)
  tradeUnionAmount          Float   @default(50)
  insuranceEnabled          Boolean @default(true)
  insurancePercentage       Float   @default(0.5)
  guaranteeFundEnabled      Boolean @default(false)
  guaranteeFundAmount       Float   @default(20)
  savingsEnabled            Boolean @default(true)
  savingsMaxPercentage      Float   @default(15)
  disciplinaryEnabled       Boolean @default(true)
  disciplinaryMaxPercentage Float   @default(50)
  courtOrderEnabled         Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([id])
  @@map("hr_settings")
}

model DashboardSettings {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Display preferences
  showFinancialAlerts  Boolean @default(true)
  showProjectAlerts    Boolean @default(true)
  showTaskAlerts       Boolean @default(true)
  showEmployeeAlerts   Boolean @default(true)
  showFreelancerAlerts Boolean @default(true)

  // Chart preferences
  defaultChartType   ChartType @default(BAR)
  showInvoiceChart   Boolean   @default(true)
  showQuotationChart Boolean   @default(true)
  showExpenseChart   Boolean   @default(true)
  showRevenueChart   Boolean   @default(true)

  // Alert thresholds
  payrollAlertDays Int @default(5)
  dueDateAlertDays Int @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dashboard_settings")
}

enum ChartType {
  BAR
  LINE
  AREA
  PIE
}

model POSSetting {
  id String @id @default(cuid())

  // VAT Settings
  vatEnabled Boolean @default(true)
  vatRate    Float   @default(0.15) // 15% default VAT

  // Delivery Settings
  deliveryEnabled   Boolean @default(true)
  deliveryFee       Float   @default(50.00)
  freeDeliveryAbove Float   @default(500.00)

  // Discount Settings
  discountEnabled Boolean @default(true)
  maxDiscountRate Float   @default(20.00)

  // Receipt Settings
  receiptHeader      String?
  receiptFooter      String?
  printAutomatically Boolean @default(false)
  emailReceipt       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================================
// ORGANIZATION STRUCTURE
// ============================================================================

model Department {
  id          String           @id @default(cuid())
  name        String
  description String?
  code        String           @unique
  managerId   String?
  parentId    String?
  status      DepartmentStatus @default(ACTIVE)
  currency    String           @default("ZAR")

  // Location
  location String?
  floor    String?
  building String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updater   String?

  // Relations
  manager     User?         @relation("DepartmentManager", fields: [managerId], references: [id])
  parent      Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[]  @relation("DepartmentHierarchy")
  employees   Employee[]    @relation("DepartmentEmployees")
  freelancers FreeLancer[]  @relation("DepartmentFreelancers")
  targets     Target[]
  budgets     Budget[]
  expenses    Transaction[]
  quotations  Quotation[]
  invoices    Invoice[]

  @@map("departments")
}

model Employee {
  id               String      @id @default(cuid())
  employeeNumber   String      @unique
  firstName        String
  lastName         String
  email            String?     @unique
  phone            String?
  avatar           String?
  position         String
  departmentId     String?
  salaryType       SalaryType? @default(MONTHLY)
  dailySalary      Decimal     @db.Decimal(15, 2)
  monthlySalary    Decimal     @db.Decimal(15, 2)
  overtimeHourRate Float       @default(50.00)

  currency        String         @default("ZAR")
  hireDate        DateTime
  terminationDate DateTime?
  status          EmployeeStatus @default(ACTIVE)

  expoPushToken String?

  canCheckByGPS Boolean @default(false)

  // Personal Information
  idNumber      String?
  taxNumber     String?
  nationality   String?
  maritalStatus MaritalStatus?

  // Address Information
  address    String?
  city       String?
  province   String?
  postalCode String?
  country    String  @default("South Africa")

  // Emergency Contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  emergencyAddress  String?

  // Banking Information
  bankName      String?
  accountNumber String?
  branchCode    String?
  accountType   String?

  // Employment Details
  contractType ContractType?
  workSchedule String?
  probationEnd DateTime?

  scheduledKnockIn         String?
  scheduledKnockOut        String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  workingDays              String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?

  // Leave Allocations
  annualLeaveDays    Int @default(21)
  sickLeaveDays      Int @default(30)
  studyLeaveDays     Int @default(5)
  maternityLeaveDays Int @default(120)
  paternityLeaveDays Int @default(10)
  unpaidLeaveDays    Int @default(0)

  medicalCondition  String?
  allergies         String?
  emergencyContacts Json?
  restrictions      String?
  firstAidNeeds     String?
  riskLevel         String?
  additionalInfo    String?

  //

  // Relations
  department           Department?            @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  assignedTasks        Task[]                 @relation(name: "TaskAssignments")
  payments             Payment[]
  documents            Document[]
  targets              Target[]
  kpiResults           KpiResult[]
  leaveRequests        LeaveRequest[]
  Note                 Note[]
  AttendanceRecord     AttendanceRecord[]
  Warning              Warning[]
  user                 User?
  employeeNotification EmployeeNotification[]
  bypassRules          AttendanceBypassRule[] @relation("BypassRuleEmployees")

  @@index([departmentId])
  @@index([status])
  @@map("employees")
}

model FreeLancer {
  id               String  @id @default(cuid())
  freeLancerNumber String  @unique
  firstName        String
  lastName         String
  email            String?
  phone            String?
  avatar           String?
  position         String
  departmentId     String?
  salary           Decimal @db.Decimal(15, 2)
  overtimeHourRate Float   @default(50.00)

  currency        String           @default("ZAR")
  hireDate        DateTime
  terminationDate DateTime?
  status          FreeLancerStatus @default(ACTIVE)
  reliable        Boolean?

  // Personal Information
  idNumber      String?
  taxNumber     String?
  nationality   String?
  maritalStatus MaritalStatus?

  // Address Information
  address    String?
  city       String?
  province   String?
  postalCode String?
  country    String  @default("South Africa")

  // Emergency Contact
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?
  emergencyAddress  String?

  // Banking Information
  bankName      String?
  accountNumber String?
  branchCode    String?
  accountType   String?

  // Employment Details
  contractType ContractType?
  workSchedule String?
  probationEnd DateTime?

  scheduledKnockIn         String?
  scheduledKnockOut        String?
  scheduledWeekendKnockIn  String?
  scheduledWeekendKnockOut String?
  workingDays              String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Leave Allocations
  annualLeaveDays    Int @default(21)
  sickLeaveDays      Int @default(30)
  studyLeaveDays     Int @default(5)
  maternityLeaveDays Int @default(120)
  paternityLeaveDays Int @default(10)
  unpaidLeaveDays    Int @default(0)

  medicalCondition  String?
  allergies         String?
  emergencyContacts Json?
  restrictions      String?
  firstAidNeeds     String?
  riskLevel         String?
  additionalInfo    String?

  // Relations
  department    Department? @relation("DepartmentFreelancers", fields: [departmentId], references: [id])
  assignedTasks Task[]      @relation(name: "FreeLancerTaskAssignments")

  payments          Payment[]
  documents         Document[]
  targets           Target[]
  kpiResults        KpiResult[]
  leaveRequests     LeaveRequest[]
  notes             Note[]
  attendanceRecords AttendanceRecord[]
  warnings          Warning[]
  bypassRules       AttendanceBypassRule[] @relation("BypassRuleFreelancers")

  @@index([departmentId])
  @@index([status])
  @@map("freelancers")
}

model AttendanceBypassRule {
  id String @id @default(cuid())

  // Date range for the bypass
  startDate DateTime
  endDate   DateTime

  // Time bypass settings
  bypassCheckIn      Boolean @default(false)
  bypassCheckOut     Boolean @default(false)
  customCheckInTime  String? // HH:mm format
  customCheckOutTime String? // HH:mm format

  // Reason for bypass
  reason String?

  // Additional info
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - Many-to-many with employees and freelancers
  employees   Employee[]   @relation("BypassRuleEmployees")
  freelancers FreeLancer[] @relation("BypassRuleFreelancers")

  @@index([startDate])
  @@index([endDate])
  @@map("attendance_bypass_rules")
}

model AttendanceRecord {
  id String @id @default(cuid())

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  freeLancerId String?
  freeLancer   FreeLancer? @relation(fields: [freeLancerId], references: [id])

  date DateTime @db.Date

  checkIn        DateTime?
  checkInLat     Decimal?       @db.Decimal(10, 8)
  checkInLng     Decimal?       @db.Decimal(11, 8)
  checkInAddress String?
  checkInMethod  CheckInMethod? @default(MANUAL)

  checkOut        DateTime?
  checkOutLat     Decimal?  @db.Decimal(10, 8)
  checkOutLng     Decimal?  @db.Decimal(11, 8)
  checkOutAddress String?

  isWeekend Boolean @default(true)

  breakStart    DateTime?
  breakEnd      DateTime?
  breakDuration Int?

  scheduledKnockIn  String?
  scheduledKnockOut String?

  // Calculated hours
  regularHours  Decimal? @db.Decimal(5, 2)
  overtimeHours Decimal? @db.Decimal(5, 2)

  status AttendanceStatus @default(PRESENT)
  notes  String?

  bypassApplied     Boolean   @default(false)
  customCheckInTime DateTime?
  bypassRuleId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@unique([freeLancerId, date])
  @@map("attendance_records")
}

model Warning {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  type            String
  severity        String
  reason          String
  actionPlan      String?
  date            DateTime  @default(now())
  status          String    @default("ACTIVE")
  resolvedAt      DateTime?
  resolutionNotes String?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  freeLancer   FreeLancer? @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@map("warnings")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  employeeId    String
  leaveType     LeaveType
  startDate     DateTime
  endDate       DateTime
  days          Int
  reason        String
  contactInfo   String?
  status        LeaveStatus @default(PENDING)
  requestedDate DateTime    @default(now())
  approvedBy    String?
  approvedDate  DateTime?
  rejectedBy    String?
  rejectedDate  DateTime?
  comments      String?

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  freeLancer   FreeLancer? @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model Account {
  id            String      @id @default(cuid())
  name          String
  accountNumber String      @unique
  type          AccountType
  subType       String?
  balance       Decimal     @db.Decimal(15, 2)
  currency      String      @default("ZAR")
  bankName      String?
  branchCode    String?
  isActive      Boolean     @default(true)
  isDefault     Boolean     @default(false)

  // Reconciliation
  lastReconciledAt  DateTime?
  reconciledBalance Decimal?  @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  fromTransfers Transfer[]    @relation(name: "FromTransfers")
  toTransfers   Transfer[]    @relation(name: "ToTransfers")
  transactions  Transaction[]

  @@map("accounts")
}

model Transaction {
  id          String            @id @default(cuid())
  amount      Decimal           @db.Decimal(15, 2)
  currency    String            @default("ZAR")
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String
  reference   String?
  date        DateTime
  method      PaymentMethod?

  // Relations
  invoiceId    String?
  categoryId   String?
  clientId     String?
  departmentId String?
  createdBy    String

  // Additional Information
  taxAmount     Decimal? @db.Decimal(15, 2)
  taxRate       Decimal? @db.Decimal(5, 4)
  netAmount     Decimal? @db.Decimal(15, 2)
  vendor        String?
  receiptUrl    String?
  invoiceNumber String?

  // Reconciliation
  isReconciled Boolean   @default(false)
  reconciledAt DateTime?
  reconciledBy String?

  // Multi-currency
  exchangeRate Decimal? @db.Decimal(10, 6)
  baseCurrency String?
  baseAmount   Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoice        Invoice?           @relation(fields: [invoiceId], references: [id])
  category       Category?          @relation(fields: [categoryId], references: [id])
  client         Client?            @relation(fields: [clientId], references: [id])
  department     Department?        @relation(fields: [departmentId], references: [id])
  creator        User               @relation(fields: [createdBy], references: [id])
  documents      Document[]
  splits         TransactionSplit[]
  Payment        Payment[]
  Account        Account?           @relation(fields: [accountId], references: [id])
  accountId      String?
  Note           Note[]
  Payroll        Payroll?
  Refund         Refund[]
  ExpensePayment ExpensePayment[]

  @@index([invoiceId])
  @@index([categoryId])
  @@index([clientId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@map("transactions")
}

model TransactionCeo {
  id            String            @id @default(cuid())
  amount        Decimal           @db.Decimal(15, 2)
  currency      String            @default("ZAR")
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  description   String
  reference     String?
  date          DateTime
  method        PaymentMethod?
  categoryCeoId String?

  // Additional Information
  vendor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  CategoryCeo CategoryCeo? @relation(fields: [categoryCeoId], references: [id])

  @@map("transactionsCeo")
}

model TransactionSplit {
  id            String   @id @default(cuid())
  transactionId String
  categoryId    String
  amount        Decimal  @db.Decimal(15, 2)
  description   String?
  percentage    Decimal? @db.Decimal(5, 2)

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id])

  @@map("transaction_splits")
}

// Update the Payroll model
model Payroll {
  id          String        @id @default(cuid())
  month       String
  description String?
  type        PaymentType
  totalAmount Float
  netAmount   Float // Add this for after deductions/bonuses
  currency    String        @default("ZAR")
  status      PayrollStatus @default(PROCESSED)

  // Original amounts
  baseAmount     Float
  overtimeAmount Float

  // New fields for totals
  totalBonuses    Float @default(0)
  totalDeductions Float @default(0)

  // Relationships
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String      @unique

  payments          Payment[]
  payrollBonuses    PayrollBonus[] // Add this relationship
  payrollDeductions PayrollDeduction[] // Add this relationship

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  @@map("payrolls")
}

// Update the Payment model
model Payment {
  id           String        @id @default(cuid())
  employeeId   String?
  freeLancerId String?
  amount       Decimal       @db.Decimal(15, 2)
  netAmount    Decimal       @db.Decimal(15, 2) // Add this for after deductions/bonuses
  currency     String        @default("ZAR")
  type         PaymentType
  description  String?
  payDate      DateTime
  status       PaymentStatus @default(PAID)

  // Original amounts
  baseAmount     Decimal @db.Decimal(15, 2)
  overtimeAmount Decimal @db.Decimal(15, 2)

  // Bonuses and deductions
  bonusAmount     Decimal @default(0) @db.Decimal(15, 2)
  deductionAmount Decimal @default(0) @db.Decimal(15, 2)

  overtimeHours Decimal? @db.Decimal(4, 2)
  regularHours  Decimal? @db.Decimal(4, 2)
  daysWorked    Int

  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  employee   Employee?   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  freeLancer FreeLancer? @relation(fields: [freeLancerId], references: [id], onDelete: Cascade)
  Payroll    Payroll?    @relation(fields: [payrollId], references: [id])
  payrollId  String?

  // Relationships for detailed bonuses/deductions
  paymentBonuses    PaymentBonus[] // Add this
  paymentDeductions PaymentDeduction[] // Add this

  @@index([employeeId])
  @@index([freeLancerId])
  @@index([payDate])
  @@map("payments")
}

// Add new models for detailed tracking
model PayrollBonus {
  id        String  @id @default(cuid())
  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  bonusType      String
  amount         Float
  description    String?
  isPercentage   Boolean @default(false)
  percentageRate Float? // If percentage-based

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payroll_bonuses")
}

model PaymentBonus {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  bonusType      String // e.g., "ANNUAL_BONUS", "PERFORMANCE_BONUS", "THIRTEENTH_CHEQUE"
  amount         Decimal @db.Decimal(15, 2)
  description    String?
  isPercentage   Boolean @default(false)
  percentageRate Float? // If percentage-based

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_bonuses")
}

model PayrollDeduction {
  id        String  @id @default(cuid())
  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  deductionType  String // e.g., "UIF", "PENSION", "MEDICAL_AID", "TAX", "LOAN_REPAYMENT"
  amount         Float
  description    String?
  isPercentage   Boolean @default(false)
  percentageRate Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payroll_deductions")
}

model PaymentDeduction {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  deductionType  String // e.g., "UIF", "PENSION", "MEDICAL_AID", "TAX", "LOAN_REPAYMENT"
  amount         Decimal @db.Decimal(15, 2)
  description    String?
  isPercentage   Boolean @default(false)
  percentageRate Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_deductions")
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

model Transfer {
  id            String         @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amount        Decimal        @db.Decimal(15, 2)
  currency      String         @default("ZAR")
  exchangeRate  Decimal?       @db.Decimal(10, 6)
  fee           Decimal?       @db.Decimal(15, 2)
  description   String?
  reference     String?
  status        TransferStatus @default(PENDING)
  transferDate  DateTime
  processedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromAccount Account @relation(name: "FromTransfers", fields: [fromAccountId], references: [id])
  toAccount   Account @relation(name: "ToTransfers", fields: [toAccountId], references: [id])

  @@map("transfers")
}

model Category {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String?
  icon        String?
  type        CategoryType
  parentId    String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)

  // Tax Information
  taxDeductible Boolean @default(false)
  taxCategory   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  parent       Category?          @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]         @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      BudgetItem[]
  splits       TransactionSplit[]
  Expense      Expense[]
  packages     Package[]

  @@map("categories")
}

model CategoryCeo {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String?
  icon        String?
  type        CategoryType
  parentId    String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)

  // Tax Information
  taxDeductible Boolean @default(false)
  taxCategory   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  transactions TransactionCeo[]

  @@map("categoriesCeo")
}

// ============================================================================
// CLIENT MANAGEMENT
// ============================================================================

model Client {
  id           String  @id @default(cuid())
  clientNumber String  @unique
  name         String
  email        String?
  phone        String  @unique
  phone2       String?
  company      String?

  // Address Information
  country  String?
  province String?
  town     String?
  village  String?
  street   String?
  address  String?

  // Company Information
  companyFullName    String?
  tradingName        String?
  registrationNumber String?
  vatNumber          String?
  taxNumber          String?
  telNo1             String?
  telNo2             String?
  website            String?

  //Company Address Information
  companyCountry  String?
  companyProvince String?
  companytown     String?
  companyvillage  String?
  companystreet   String?
  companyaddress  String?

  // Additional Information
  additionalInfo String?

  avatar String?
  status ClientStatus @default(ACTIVE)
  type   ClientType   @default(INDIVIDUAL)

  // Existing financial information
  creditLimit  Decimal? @db.Decimal(15, 2)
  paymentTerms Int? // Days
  currency     String   @default("ZAR")

  // Relationship
  assignedTo String?
  source     String?
  notes      String?
  createdBy  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invoices          Invoice[]
  transactions      Transaction[]
  documents         Document[]
  projects          Project[]
  quotations        Quotation[]
  Note              Note[]
  toolRentals       ToolRental[]
  recurringInvoices RecurringInvoice[]

  @@index([status])
  @@index([type])
  @@map("clients")
}

model Project {
  id            String        @id @default(cuid())
  projectNumber String
  title         String
  description   String?
  projectType   ProjectType   @default(NEW_PROJECT)
  billingType   BillingType?
  clientId      String?
  managerId     String
  status        ProjectStatus @default(PLANNING)
  priority      Priority      @default(MEDIUM)
  starred       Boolean       @default(false)
  archived      Boolean       @default(false)

  // Timeline
  startDate DateTime?
  endDate   DateTime?
  deadline  DateTime?

  // Financial
  budget      Decimal? @db.Decimal(15, 2)
  budgetSpent Decimal? @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  hourlyRate  Decimal? @db.Decimal(10, 2)

  // Progress
  progress Int @default(0) // 0-100

  // Daily work tracking
  workLogs WorkLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client      Client?       @relation(fields: [clientId], references: [id])
  manager     User?         @relation(fields: [managerId], references: [id])
  teamMembers ProjectTeam[]

  tasks         Task[]
  timeEntries   TimeEntry[]
  invoices      Invoice[]
  quotations    Quotation[]
  documents     Document[]
  Note          Note[]
  Folder        Folder[]
  comment       comment[]
  toolInterUses ToolInterUse[]
  Expense       Expense[]
  service       Service?       @relation(fields: [serviceId], references: [id])
  serviceId     String?

  @@index([clientId])
  @@index([status])
  @@index([projectType])
  @@map("projects")
}

model WorkLog {
  id          String   @id @default(cuid())
  date        DateTime
  hours       Decimal  @db.Decimal(5, 2)
  description String
  projectId   String
  userId      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
  @@map("work_logs")
}

model ProjectTeam {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String?

  // Permissions
  canEditTask      Boolean @default(false)
  canDeleteTask    Boolean @default(false)
  canDeleteFiles   Boolean @default(false)
  canCreateTask    Boolean @default(false)
  canAddInvoice    Boolean @default(false)
  canUploadFiles   Boolean @default(false)
  canEditFile      Boolean @default(false)
  canViewFinancial Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_teams")
}

model Task {
  id            String     @id @default(cuid())
  taskNumber    String
  title         String
  description   String?
  projectId     String
  status        TaskStatus @default(TODO)
  priority      Priority   @default(MEDIUM)
  noteId        String?
  isAIGenerated Boolean    @default(false)

  // Timeline
  dueDate     DateTime?
  completedAt DateTime?

  // Estimation
  estimatedHours Decimal? @db.Decimal(8, 2)
  actualHours    Decimal? @db.Decimal(8, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project             Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignees           Employee[]   @relation("TaskAssignments")
  freeLancerAssignees FreeLancer[] @relation("FreeLancerTaskAssignments")
  freelancerId        String?
  comment             comment[]
  documents           Document[]
  timeEntries         TimeEntry[]
  subtask             Subtask[]

  @@index([projectId])
  @@index([status])
  @@index([freelancerId])
  @@map("tasks")
}

model Subtask {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  estimatedHours Float?
  order          Int
  taskId         String
  task           Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Document {
  id           String       @id @default(cuid())
  name         String
  originalName String?
  type         DocumentType
  url          String
  size         Int?
  mimeType     String?
  checksum     String?

  starred Boolean @default(false)
  shared  Boolean @default(false)

  // Relations (polymorphic)
  employeeId    String?
  clientId      String?
  transactionId String?
  projectId     String?
  venderId      String?

  folderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee    Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  vender      Vendor?      @relation(fields: [venderId], references: [id], onDelete: Cascade)

  Project      Project?    @relation(fields: [projectId], references: [id])
  folder       Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  Task         Task?       @relation(fields: [taskId], references: [id])
  taskId       String?
  freeLancer   FreeLancer? @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@index([type])
  @@index([employeeId])
  @@index([clientId])
  @@index([transactionId])
  @@map("documents")
}

model comment {
  id      String @id @default(cuid())
  content String

  projectId       String?
  liked           Boolean @default(false)
  pinned          Boolean @default(false)
  commenterName   String
  commenterId     String
  commenterAvatar String?
  commenterRole   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  commentReply commentReply[]
  Task         Task?          @relation(fields: [taskId], references: [id])
  taskId       String?
}

model Note {
  id            String   @id @default(cuid())
  title         String
  content       String
  tags          String[]
  // Relations (polymorphic)
  employeeId    String?
  clientId      String?
  transactionId String?
  projectId     String?
  folderId      String?
  color         String?
  pinned        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction  Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  Project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder       Folder?      @relation(fields: [folderId], references: [id], onDelete: Cascade)
  freeLancer   FreeLancer?  @relation(fields: [freeLancerId], references: [id])
  freeLancerId String?

  @@index([employeeId])
  @@index([clientId])
  @@index([transactionId])
}

model commentReply {
  id        String  @id @default(cuid())
  content   String
  commentId String
  liked     Boolean @default(false)

  commenterName   String
  commenterId     String
  commenterAvatar String?
  commenterRole   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comment   comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Folder {
  id    String @id @default(cuid())
  title String

  // Relations (polymorphic)
  projectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Project  Project?   @relation(fields: [projectId], references: [id])
  Note     Note[]
  Document Document[]

  @@index([projectId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  projectId   String?
  taskId      String?
  description String?
  hours       Decimal   @db.Decimal(8, 2)
  hourlyRate  Decimal?  @db.Decimal(10, 2)
  timeIn      DateTime
  timeOut     DateTime?
  date        DateTime

  images String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
  userId  String
  user    User     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([date])
  @@index([taskId])
  @@map("time_entries")
}

// ============================================================================
// BUDGET MANAGEMENT
// ============================================================================

model Budget {
  id           String       @id @default(cuid())
  name         String
  description  String?
  totalAmount  Decimal      @db.Decimal(15, 2)
  currency     String       @default("ZAR")
  startDate    DateTime
  endDate      DateTime
  status       BudgetStatus @default(ACTIVE)
  departmentId String?

  // Approval
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  department Department?   @relation(fields: [departmentId], references: [id])
  items      BudgetItem[]
  alerts     BudgetAlert[]

  @@index([departmentId])
  @@index([status])
  @@map("budgets")
}

model BudgetItem {
  id         String  @id @default(cuid())
  budgetId   String
  categoryId String
  amount     Decimal @db.Decimal(15, 2)
  spent      Decimal @default(0) @db.Decimal(15, 2)
  currency   String  @default("ZAR")
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget   Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([budgetId, categoryId])
  @@map("budget_items")
}

model BudgetAlert {
  id          String          @id @default(cuid())
  budgetId    String
  type        BudgetAlertType
  threshold   Decimal         @db.Decimal(5, 2) // Percentage
  triggered   Boolean         @default(false)
  triggeredAt DateTime?
  message     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("budget_alerts")
}

// ============================================================================
// INVOICE MANAGEMENT
// ============================================================================

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  project       String?
  amount        Decimal       @db.Decimal(15, 2)
  currency      String        @default("ZAR")
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime
  dueDate       DateTime
  paidDate      DateTime?

  // Invoice Details
  description    String?
  taxAmount      Decimal?      @db.Decimal(15, 2)
  taxRate        Decimal?      @db.Decimal(5, 2)
  discountAmount Decimal?      @db.Decimal(15, 2)
  discountType   DiscountType? @default(AMOUNT)
  totalAmount    Decimal       @db.Decimal(15, 2)

  depositType     DepositType? @default(AMOUNT)
  depositAmount   Decimal?     @db.Decimal(15, 2)
  depositRate     Decimal?     @db.Decimal(15, 2)
  depositRequired Boolean      @default(false)

  // Terms
  paymentTerms String?
  notes        String?
  terms        String?

  // Relations
  createdBy String

  // Recurring
  isRecurring Boolean @default(false)
  recurringId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client            @relation(fields: [clientId], references: [id])
  creator      User              @relation(fields: [createdBy], references: [id])
  items        InvoiceItem[]
  payments     InvoicePayment[]
  recurring    RecurringInvoice? @relation(fields: [recurringId], references: [id])
  Project      Project?          @relation(fields: [projectId], references: [id])
  projectId    String?
  Department   Department?       @relation(fields: [departmentId], references: [id])
  departmentId String?
  Transaction  Transaction[]
  toolRentals  ToolRental[]
  Expense      Expense[]
  package      Package?          @relation(fields: [packageId], references: [id])
  packageId    String?

  // Package and Subpackage relations

  subpackageId String?
  subpackage   Subpackage? @relation(fields: [subpackageId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  taxRate     Decimal? @db.Decimal(5, 2)
  taxAmount   Decimal? @db.Decimal(15, 2)

  itemDiscountType   DiscountType?
  itemDiscountAmount Decimal?

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  shopProductId String?
  shopProduct   ShopProduct? @relation(fields: [shopProductId], references: [id])

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model RecurringInvoice {
  id        String             @id @default(cuid())
  clientId  String
  frequency RecurringFrequency
  interval  Int                @default(1)
  startDate DateTime
  endDate   DateTime?
  nextDate  DateTime
  status    RecurringStatus    @default(ACTIVE)

  // Template data (stores the invoice template)
  description    String?
  items          Json
  currency       String        @default("ZAR")
  taxRate        Decimal?      @db.Decimal(5, 2)
  discountAmount Decimal?      @db.Decimal(15, 2)
  discountType   DiscountType? @default(AMOUNT)
  paymentTerms   String?
  notes          String?

  depositType     DepositType? @default(AMOUNT)
  depositAmount   Decimal?     @db.Decimal(15, 2)
  depositRequired Boolean      @default(false)
  depositRate     Decimal?     @db.Decimal(15, 2)

  // Metadata
  totalInvoicesGenerated Int       @default(0)
  lastGeneratedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  client   Client    @relation(fields: [clientId], references: [id])
  creator  String
  user     User      @relation(fields: [creator], references: [id])
  invoices Invoice[]

  @@map("recurring_invoices")
}

model InvoicePayment {
  id        String               @id @default(cuid())
  invoiceId String
  amount    Decimal              @db.Decimal(15, 2)
  currency  String               @default("ZAR")
  method    PaymentMethod
  reference String?
  notes     String?
  status    InvoicePaymentStatus @default(PENDING)
  paidAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_payments")
}

// ============================================================================
// QUOTATION MANAGEMENT
// ============================================================================

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  clientId        String
  projectId       String?
  amount          Decimal         @db.Decimal(15, 2)
  currency        String          @default("ZAR")
  status          QuotationStatus @default(DRAFT)
  issueDate       DateTime
  validUntil      DateTime
  acceptedDate    DateTime?
  rejectedDate    DateTime?

  // Quotation Details
  title          String?
  description    String?
  taxAmount      Decimal?      @db.Decimal(15, 2)
  taxRate        Decimal?      @db.Decimal(5, 2)
  discountAmount Decimal?      @db.Decimal(15, 2)
  discountType   DiscountType? @default(AMOUNT)
  totalAmount    Decimal       @db.Decimal(15, 2)

  depositType     DepositType? @default(AMOUNT)
  depositAmount   Decimal?     @db.Decimal(15, 2)
  depositRequired Boolean      @default(false)
  depositRate     Decimal?     @db.Decimal(15, 2)

  // Terms and Conditions
  terms         String?
  notes         String?
  paymentTerms  String?
  deliveryTerms String?

  // Conversion
  convertedToInvoice Boolean @default(false)
  invoiceId          String?

  // Relations
  createdBy String

  // Follow-up
  followUpDate DateTime?
  reminderSent Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client   @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  creator User     @relation(fields: [createdBy], references: [id])

  items        QuotationItem[]
  Department   Department?     @relation(fields: [departmentId], references: [id])
  departmentId String?
  toolRentals  ToolRental[]
  package      Package?        @relation(fields: [packageId], references: [id])
  packageId    String?

  subpackageId String?
  subpackage   Subpackage? @relation(fields: [subpackageId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([validUntil])
  @@index([createdBy])
  @@map("quotations")
}

model QuotationItem {
  id          String   @id @default(cuid())
  quotationId String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("ZAR")
  taxRate     Decimal? @db.Decimal(5, 2)
  taxAmount   Decimal? @db.Decimal(15, 2)
  notes       String?
  sortOrder   Int      @default(0)

  itemDiscountType   DiscountType?
  itemDiscountAmount Decimal?

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  shopProductId String?
  shopProduct   ShopProduct? @relation(fields: [shopProductId], references: [id])

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@map("quotation_items")
}

